---
// The hero emblem (PDF p.20): a sun disc whose light fans out into two
// great wings of rays — a bird soaring out of the dawn. Pure geometry.
interface Props {
  size?: number;
  class?: string;
}
const { size = 520, class: className = '' } = Astro.props;

const W = 1000;
const H = 620;
const cx = W / 2;
const cy = H * 0.52;
const gold = '#E7C68B';
const ochre = '#CC914E';

type Feather = { d: string; o: number; sw: number };

function wing(side: 1 | -1): Feather[] {
  const feathers: Feather[] = [];
  const n = 26;
  for (let i = 0; i < n; i++) {
    const s = i / (n - 1);
    // angle sweeps from slightly-up (inner) to downward (wingtip)
    const deg = -34 + s * 74;
    const a = deg * (Math.PI / 180);
    // length peaks toward mid-wing then tapers at the tip
    const len = 70 + 380 * Math.sin(Math.PI * (0.18 + 0.74 * s));
    const rootR = 26 + s * 10;
    const x1 = cx + side * rootR * Math.cos(a * 0.4);
    const y1 = cy + rootR * Math.sin(a * 0.4);
    const x2 = cx + side * (rootR + len) * Math.cos(a);
    const y2 = cy + (rootR + len) * Math.sin(a);
    // gentle upward bow via perpendicular control point
    const mx = (x1 + x2) / 2;
    const my = (y1 + y2) / 2;
    const bow = 26 * (1 - s);
    const ctrlX = mx;
    const ctrlY = my - bow;
    feathers.push({
      d: `M${x1.toFixed(1)} ${y1.toFixed(1)} Q${ctrlX.toFixed(1)} ${ctrlY.toFixed(1)} ${x2.toFixed(1)} ${y2.toFixed(1)}`,
      o: 0.32 + 0.55 * Math.sin(Math.PI * s),
      sw: 1.3 - 0.5 * s,
    });
  }
  return feathers;
}

// Upward halo rays above the disc (the crown of light)
const halo: { x2: number; y2: number; o: number }[] = [];
const haloN = 17;
for (let i = 0; i < haloN; i++) {
  const t = i / (haloN - 1);
  const a = (-66 + t * 132) * (Math.PI / 180);
  const len = 120 + 70 * Math.cos(a);
  halo.push({
    x2: cx + len * Math.sin(a),
    y2: cy - len * Math.cos(a),
    o: 0.25 + 0.4 * Math.cos(a) * Math.cos(a),
  });
}

const right = wing(1);
const left = wing(-1);
---

<svg
  viewBox={`0 0 ${W} ${H}`}
  width={size}
  height={(size * H) / W}
  fill="none"
  role="img"
  aria-label="A bird of light rising from the dawn"
  class={className}
>
  <defs>
    <radialGradient id="discGlow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#FBEFD3" />
      <stop offset="55%" stop-color={ochre} />
      <stop offset="100%" stop-color="#8a5a28" />
    </radialGradient>
  </defs>

  <!-- crown of light -->
  <g stroke={gold} stroke-width="1.2" stroke-linecap="round">
    {halo.map((r) => <line x1={cx} y1={cy} x2={r.x2} y2={r.y2} opacity={r.o} />)}
  </g>

  <!-- wings of rays -->
  <g stroke={gold} stroke-linecap="round" fill="none">
    {left.map((f) => <path d={f.d} opacity={f.o} stroke-width={f.sw} />)}
    {right.map((f) => <path d={f.d} opacity={f.o} stroke-width={f.sw} />)}
  </g>

  <!-- the rising sun disc -->
  <circle cx={cx} cy={cy} r="30" fill="url(#discGlow)" />
  <circle cx={cx} cy={cy} r="30" fill="none" stroke={gold} stroke-width="1.5" />
  <circle cx={cx} cy={cy} r="44" fill="none" stroke={gold} stroke-width="0.6" opacity="0.5" />
</svg>
