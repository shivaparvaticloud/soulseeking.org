---
// ────────────────────────────────────────────────────────────────────────────
// The Cosmos & The Sheaths — the home-page flagship.
// The five concentric veils of the Self (pañca-maya-kośa) as a still, luminous
// SVG composition adrift in a field of stars. Each sheath is selectable by
// pointer or keyboard, and choosing one updates the caption — so the teaching is
// fully reachable with no WebGL, no 3D and no per-frame work. Light and instant.
// ────────────────────────────────────────────────────────────────────────────

// Outer → inner. Colours are warm and candle-lit; the Self sits at the centre.
const sheaths = [
  { key: 'anna', sanskrit: 'Annamaya', name: 'The Food Sheath', line: 'The body you can touch — made of, and fed by, food.', color: '#7A5A3A' },
  { key: 'prana', sanskrit: 'Prāṇamaya', name: 'The Breath Sheath', line: 'The vital air — the life that moves and warms the body.', color: '#CC5B3A' },
  { key: 'mano', sanskrit: 'Manomaya', name: 'The Mind Sheath', line: 'Thought and feeling — the restless surface of the mind.', color: '#CC914E' },
  { key: 'vijnana', sanskrit: 'Vijñānamaya', name: 'The Wisdom Sheath', line: 'The knower that discerns — intellect and inner judgement.', color: '#E7C68B' },
  { key: 'ananda', sanskrit: 'Ānandamaya', name: 'The Bliss Sheath', line: 'The quiet of deep peace — the veil nearest the Self.', color: '#F3E6C8' },
];
const self = { sanskrit: 'Ātman', name: 'The Self', line: 'The witness the five sheaths conceal — unchanging, ever-free.' };
---

<section
  class="relative overflow-hidden bg-cosmos text-cream"
  data-kosa
  aria-labelledby="kosa-title"
>
  <div class="mx-auto max-w-5xl px-6 py-phi-4">
    <div class="text-center">
      <p class="accent text-gold">The Cosmos &amp; the Sheaths</p>
      <h2 id="kosa-title" class="mt-2 text-3xl tracking-extreme text-cream sm:text-4xl">
        The Five Veils of the Self
      </h2>
      <p class="mx-auto mt-phi-1 max-w-xl leading-relaxed text-cream/70">
        The Self is wrapped in five sheaths, from the body to the bliss nearest within.
        Move through them — gently — and see what each one veils.
      </p>
    </div>

    <!-- Stage: a still SVG composition of the five veils around a bright centre. -->
    <div class="relative mx-auto mt-phi-2 aspect-[4/3] w-full max-w-2xl sm:aspect-[16/10]">
      <div data-kosa-fallback class="absolute inset-0 grid place-items-center">
        <svg viewBox="0 0 400 320" class="h-full w-full" role="img" aria-label="Five concentric veils of light around a bright centre, adrift in a field of stars">
          <defs>
            <radialGradient id="kosaCore" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#FBF6EA" stop-opacity="0.95"></stop>
              <stop offset="40%" stop-color="#E7C68B" stop-opacity="0.5"></stop>
              <stop offset="100%" stop-color="#E7C68B" stop-opacity="0"></stop>
            </radialGradient>
          </defs>
          {
            [110, 90, 70, 50, 32].map((rr, i) => (
              <circle
                cx="200"
                cy="160"
                r={rr}
                fill="none"
                stroke={sheaths[i].color}
                stroke-width="1"
                opacity={0.22 + i * 0.12}
                data-kosa-ring
                data-ring-index={i}
              />
            ))
          }
          <circle cx="200" cy="160" r="46" fill="url(#kosaCore)"></circle>
          <circle cx="200" cy="160" r="4" fill="#FBF6EA"></circle>
          {
            Array.from({ length: 60 }).map((_, i) => {
              const a = (i * 137.5 * Math.PI) / 180;
              const rad = 18 + (i / 60) * 150;
              return (
                <circle
                  cx={(200 + Math.cos(a) * rad).toFixed(1)}
                  cy={(160 + Math.sin(a) * rad * 0.8).toFixed(1)}
                  r={i % 7 === 0 ? 1.4 : 0.7}
                  fill="#E7C68B"
                  opacity={0.15 + (i % 5) * 0.08}
                />
              );
            })
          }
        </svg>
      </div>
    </div>

    <!-- Live caption — announces the chosen sheath -->
    <p
      data-kosa-caption
      aria-live="polite"
      class="mx-auto mt-phi-2 min-h-[3.5rem] max-w-xl text-center leading-relaxed text-cream/85"
    >
      <span class="accent text-gold">{self.sanskrit}</span>
      <span class="mt-1 block text-lg italic text-cream">{self.line}</span>
    </p>

    <!-- Keyboard-accessible selectors -->
    <div class="mt-phi-1 flex flex-wrap items-center justify-center gap-2" role="group" aria-label="The five sheaths">
      {
        sheaths.map((s, i) => (
          <button
            type="button"
            data-kosa-btn
            data-index={i}
            data-color={s.color}
            data-sanskrit={s.sanskrit}
            data-name={s.name}
            data-line={s.line}
            aria-pressed="false"
            class="min-h-[2.75rem] rounded-full border border-gold/40 px-4 py-2 text-[0.62rem] uppercase tracking-extreme text-cream/75 transition-phi hover:border-gold hover:text-gold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold aria-pressed:border-gold aria-pressed:bg-gold/10 aria-pressed:text-gold"
          >
            {s.sanskrit}
          </button>
        ))
      }
      <button
        type="button"
        data-kosa-btn
        data-index="5"
        data-color="#FBF6EA"
        data-sanskrit={self.sanskrit}
        data-name={self.name}
        data-line={self.line}
        aria-pressed="true"
        class="min-h-[2.75rem] rounded-full border border-gold/60 bg-gold/10 px-4 py-2 text-[0.62rem] uppercase tracking-extreme text-gold transition-phi hover:border-gold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold"
      >
        {self.sanskrit}
      </button>
    </div>
  </div>

  <script>
    type Sheath = { index: number; sanskrit: string; line: string };

    // Pointer/keyboard selection of the five veils — updates the caption and
    // brightens the chosen ring. Pure DOM work; no libraries, no render loop.
    function initKosa() {
      const sectionEl = document.querySelector('[data-kosa]') as HTMLElement | null;
      if (!sectionEl || sectionEl.dataset.kosaBound === '1') return;
      sectionEl.dataset.kosaBound = '1';

      const caption = sectionEl.querySelector('[data-kosa-caption]') as HTMLElement;
      const buttons = Array.from(sectionEl.querySelectorAll('[data-kosa-btn]')) as HTMLButtonElement[];
      const rings = Array.from(sectionEl.querySelectorAll('[data-kosa-ring]')) as SVGCircleElement[];
      if (!caption || !buttons.length) return;

      const sheaths: Sheath[] = buttons.map((b, i) => ({
        index: i,
        sanskrit: b.dataset.sanskrit || '',
        line: b.dataset.line || '',
      }));

      const renderCaption = (s: Sheath) => {
        caption.innerHTML =
          '<span class="accent text-gold">' +
          s.sanskrit +
          '</span><span class="mt-1 block text-lg italic text-cream">' +
          s.line +
          '</span>';
      };

      const select = (i: number) => {
        buttons.forEach((b, bi) => b.setAttribute('aria-pressed', String(bi === i)));
        rings.forEach((ring, ri) => {
          ring.style.opacity = ri === i ? '0.85' : '';
          ring.style.strokeWidth = ri === i ? '1.8' : '';
        });
        renderCaption(sheaths[i]);
      };

      buttons.forEach((b, i) => {
        b.addEventListener('click', () => select(i));
        b.addEventListener('mouseenter', () => select(i));
        b.addEventListener('focus', () => select(i));
      });
    }

    initKosa();
    document.addEventListener('astro:page-load', initKosa);
  </script>
</section>
