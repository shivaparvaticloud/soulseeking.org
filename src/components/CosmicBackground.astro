---
interface Props { variant?: string; class?: string; }
const { variant = 'starfield', class: className = '' } = Astro.props;

// Per-instance unique id suffix so SVG gradient/filter ids never collide.
const uid = Math.random().toString(36).slice(2, 7);

// --- Star-layer helper: build a multi-star box-shadow string ---
function makeStars(count: number, spread: number, color: string): string {
  const out: string[] = [];
  for (let i = 0; i < count; i++) {
    const x = Math.round(Math.random() * spread);
    const y = Math.round(Math.random() * spread);
    out.push(`${x}px ${y}px 0 ${color}`);
  }
  return out.join(', ');
}

const starsA = makeStars(120, 2000, 'rgba(243,230,200,0.9)');
const starsB = makeStars(80, 2000, 'rgba(236,234,227,0.7)');
const starsC = makeStars(50, 2000, 'rgba(231,198,139,0.6)');

// --- HD star field (crisp SVG circles, varied size/colour/brightness) ---
const STAR_COLS = ['#FBF6EA', '#F3E6C8', '#E7C68B', '#CC914E', '#BCD0F0', '#EEEDE3'];
let s2 = 99173;
const sr = () => ((s2 = (s2 * 1103515245 + 12345) & 0x7fffffff) / 0x7fffffff);
const hdStars = Array.from({ length: 240 }, () => {
  const r = Math.pow(sr(), 2.4) * 1.7 + 0.25; // many faint, few large
  return {
    cx: +(sr() * 1000).toFixed(1),
    cy: +(sr() * 1000).toFixed(1),
    r: +r.toFixed(2),
    o: +(0.25 + sr() * 0.6).toFixed(2),
    c: STAR_COLS[(sr() * STAR_COLS.length) | 0],
  };
});
const brightStars = Array.from({ length: 9 }, () => ({
  cx: +(sr() * 1000).toFixed(1),
  cy: +(sr() * 1000).toFixed(1),
  r: +(1.4 + sr() * 1.3).toFixed(2),
  c: STAR_COLS[(sr() * 4) | 0],
}));


// --- Galaxy spiral arm dots ---
const arms = [0, 1, 2, 3];
function spiralArm(armIndex: number) {
  const dots = [];
  const base = (armIndex / arms.length) * Math.PI * 2;
  for (let i = 0; i < 26; i++) {
    const t = i / 26;
    const r = 6 + t * 44;
    const a = base + t * 3.2;
    dots.push({
      cx: 50 + Math.cos(a) * r,
      cy: 50 + Math.sin(a) * r,
      rr: Math.max(0.25, 1.1 - t),
      o: Math.max(0.12, 0.85 - t * 0.8),
    });
  }
  return dots;
}
---

<div class={`cosmic absolute inset-0 overflow-hidden ${className}`} aria-hidden="true">

  <!-- Realistic deep-space base, shared by every scene: drifting interstellar
       gas (fractal-noise), a crisp HD star field, and fine sensor grain. -->
  <div class="deep">
    <div class="deep-gas deep-gas-1"></div>
    <div class="deep-gas deep-gas-2"></div>
    <div class="deep-gas deep-gas-3"></div>
    <svg class="hd-stars" viewBox="0 0 1000 1000" preserveAspectRatio="xMidYMid slice">
      <defs>
        <radialGradient id={`bs-${uid}`} cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity="0.95" />
          <stop offset="35%" stop-color="#F3E6C8" stop-opacity="0.5" />
          <stop offset="100%" stop-color="#E7C68B" stop-opacity="0" />
        </radialGradient>
      </defs>
      {hdStars.map((s) => <circle cx={s.cx} cy={s.cy} r={s.r} fill={s.c} opacity={s.o} />)}
      {brightStars.map((s) => (
        <Fragment>
          <circle cx={s.cx} cy={s.cy} r={s.r * 5} fill={`url(#bs-${uid})`} />
          <circle cx={s.cx} cy={s.cy} r={s.r} fill="#ffffff" />
        </Fragment>
      ))}
    </svg>
    <div class="deep-grain"></div>
  </div>

  {variant === 'blackhole' && (
    <div class="scene">
      <div class="stars stars-c"></div>
    </div>
  )}

  {variant === 'galaxy' && (
    <div class="scene">
      <div class="stars stars-a"></div>
    </div>
  )}

  {variant === 'nebula' && (
    <div class="scene">
      <div class="stars stars-b"></div>
      <div class="neb neb-1"></div>
      <div class="neb neb-2"></div>
      <div class="neb neb-3"></div>
      <div class="neb neb-4"></div>
    </div>
  )}

  {variant === 'wormhole' && (
    <div class="scene">
      <div class="stars stars-c"></div>
    </div>
  )}

  {variant === 'supernova' && (
    <div class="scene">
      <div class="stars stars-c"></div>
    </div>
  )}

  {variant === 'aurora' && (
    <div class="scene">
      <div class="stars stars-b"></div>
      <div class="au au-1"></div>
      <div class="au au-2"></div>
      <div class="au au-3"></div>
    </div>
  )}

  {variant === 'comets' && (
    <div class="scene">
      <div class="stars stars-a"></div>
      <div class="comet comet-1"></div>
      <div class="comet comet-2"></div>
      <div class="comet comet-3"></div>
    </div>
  )}

  {variant === 'eclipse' && (
    <div class="scene">
      <div class="stars stars-c"></div>
    </div>
  )}

  {variant === 'starfield' && (
    <div class="scene">
      <div class="stars stars-c sf-slow"></div>
      <div class="stars stars-b sf-mid"></div>
      <div class="stars stars-a sf-fast"></div>
    </div>
  )}

  {variant === 'pulsar' && (
    <div class="scene">
      <div class="stars stars-c"></div>
    </div>
  )}

  <div class="vignette"></div>
</div>

<style define:vars={{ starsA, starsB, starsC }}>
  .cosmic { background: radial-gradient(120% 100% at 50% 30%, #0c0b12 0%, #08080a 60%, #060608 100%); }
  .scene { position: absolute; inset: 0; }

  /* ---------- REALISTIC DEEP-SPACE BASE ---------- */
  .deep { position: absolute; inset: 0; }
  .deep-gas {
    position: absolute; inset: -18%;
    background-size: cover; background-position: center;
    will-change: transform;
  }
  /* warm hydrogen gold gas */
  .deep-gas-1 {
    opacity: 0.55; filter: blur(5px) saturate(1.1);
    background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='760'%20height='760'%3E%3Cfilter%20id='g'%3E%3CfeTurbulence%20type='fractalNoise'%20baseFrequency='0.0055%200.009'%20numOctaves='4'%20seed='5'/%3E%3CfeColorMatrix%20type='matrix'%20values='0%200%200%200%200.82%200%200%200%200%200.58%200%200%200%200%200.30%201.15%200%200%200%20-0.5'/%3E%3C/filter%3E%3Crect%20width='760'%20height='760'%20filter='url(%23g)'/%3E%3C/svg%3E");
    animation: gasDrift1 80s ease-in-out infinite;
  }
  /* deep violet nebula */
  .deep-gas-2 {
    opacity: 0.45; filter: blur(9px);
    background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='820'%20height='820'%3E%3Cfilter%20id='g'%3E%3CfeTurbulence%20type='fractalNoise'%20baseFrequency='0.0072%200.006'%20numOctaves='4'%20seed='12'/%3E%3CfeColorMatrix%20type='matrix'%20values='0%200%200%200%200.34%200%200%200%200%200.22%200%200%200%200%200.52%200%201.05%200%200%20-0.52'/%3E%3C/filter%3E%3Crect%20width='820'%20height='820'%20filter='url(%23g)'/%3E%3C/svg%3E");
    animation: gasDrift2 105s ease-in-out infinite;
  }
  /* dark dust lanes for depth */
  .deep-gas-3 {
    opacity: 0.5; filter: blur(3px);
    background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='900'%20height='900'%3E%3Cfilter%20id='g'%3E%3CfeTurbulence%20type='fractalNoise'%20baseFrequency='0.0035%200.0045'%20numOctaves='5'%20seed='23'/%3E%3CfeColorMatrix%20type='matrix'%20values='0%200%200%200%200.04%200%200%200%200%200.03%200%200%200%200%200.03%200%200%201.2%200%20-0.55'/%3E%3C/filter%3E%3Crect%20width='900'%20height='900'%20filter='url(%23g)'/%3E%3C/svg%3E");
    animation: gasDrift1 140s ease-in-out infinite reverse;
  }
  @keyframes gasDrift1 {
    0%,100% { transform: translate3d(0,0,0) scale(1.06); }
    50% { transform: translate3d(2.5%,-2%,0) scale(1.14); }
  }
  @keyframes gasDrift2 {
    0%,100% { transform: translate3d(0,0,0) scale(1.12); }
    50% { transform: translate3d(-3%,2.5%,0) scale(1.0); }
  }
  .hd-stars {
    position: absolute; inset: -7%; width: 114%; height: 114%;
    will-change: transform;
    animation: star-drift 150s ease-in-out infinite alternate;
  }
  @keyframes star-drift {
    0% { transform: translate3d(-1.6%, -1.1%, 0) scale(1.02); }
    100% { transform: translate3d(1.6%, 1.3%, 0) scale(1.05); }
  }
  .deep-grain {
    position: absolute; inset: 0; opacity: 0.04;
    background-size: 200px 200px;
    background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='160'%20height='160'%3E%3Cfilter%20id='n'%3E%3CfeTurbulence%20type='fractalNoise'%20baseFrequency='0.8'%20numOctaves='2'%20stitchTiles='stitch'/%3E%3C/filter%3E%3Crect%20width='160'%20height='160'%20filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* Central + edge vignette keeps foreground text legible */
  .vignette {
    position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(120% 90% at 50% 50%, rgba(8,8,10,0) 38%, rgba(8,8,10,0.72) 100%),
      radial-gradient(60% 50% at 50% 46%, rgba(8,8,10,0.45), rgba(8,8,10,0) 70%);
  }

  /* ---------- STAR LAYERS (box-shadow technique) ---------- */
  .stars {
    position: absolute; top: 0; left: 0;
    width: 1px; height: 1px; border-radius: 50%;
    background: transparent;
    will-change: opacity;
    transform: translateZ(0);
  }
  .stars-a { box-shadow: var(--starsA); animation: twinkleA 7s ease-in-out infinite; }
  .stars-b { box-shadow: var(--starsB); animation: twinkleB 9s ease-in-out infinite; }
  .stars-c { box-shadow: var(--starsC); animation: twinkleA 11s ease-in-out infinite; }
  @keyframes twinkleA { 0%,100% { opacity: .55; } 50% { opacity: .95; } }
  @keyframes twinkleB { 0%,100% { opacity: .85; } 50% { opacity: .45; } }

  /* ---------- BLACKHOLE ---------- */
  .bh-glow {
    position: absolute; left: 50%; top: 50%; width: 60vmin; height: 60vmin;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(204,91,58,0.35), rgba(204,145,78,0.18) 40%, transparent 68%);
    filter: blur(14px);
  }
  .bh-ring {
    position: absolute; left: 50%; top: 50%; width: 40vmin; height: 40vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    background: conic-gradient(from 0deg,
      #692828, #CC5B3A, #E7C68B, #F3E6C8, #CC914E, #692828);
    -webkit-mask: radial-gradient(circle, transparent 40%, #000 42%, #000 70%, transparent 73%);
    mask: radial-gradient(circle, transparent 40%, #000 42%, #000 70%, transparent 73%);
    will-change: transform; animation: spin 26s linear infinite;
  }
  .bh-core {
    position: absolute; left: 50%; top: 50%; width: 17vmin; height: 17vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    background: radial-gradient(circle, #050506 60%, rgba(8,8,10,0.2) 100%);
    box-shadow: 0 0 6vmin 2vmin rgba(231,198,139,0.18);
  }
  @keyframes spin { to { transform: translate(-50%, -50%) rotate(360deg); } }

  /* ---------- GALAXY ---------- */
  .galaxy {
    position: absolute; left: 50%; top: 50%; width: 92vmin; height: 92vmin;
    transform: translate(-50%, -50%); opacity: .85;
    will-change: transform; animation: spin 120s linear infinite;
  }

  /* ---------- NEBULA ---------- */
  .neb {
    position: absolute; border-radius: 50%;
    will-change: transform, opacity;
  }
  .neb-1 {
    left: 20%; top: 30%; width: 70vmin; height: 70vmin;
    background: radial-gradient(circle, rgba(204,145,78,0.5), transparent 65%);
    filter: blur(22px); animation: drift1 34s ease-in-out infinite;
  }
  .neb-2 {
    left: 55%; top: 45%; width: 64vmin; height: 64vmin;
    background: radial-gradient(circle, rgba(231,198,139,0.42), transparent 65%);
    filter: blur(24px); animation: drift2 40s ease-in-out infinite;
  }
  .neb-3 {
    left: 38%; top: 60%; width: 56vmin; height: 56vmin;
    background: radial-gradient(circle, rgba(204,91,58,0.34), transparent 64%);
    filter: blur(20px); animation: drift1 46s ease-in-out infinite reverse;
  }
  .neb-4 {
    left: 62%; top: 22%; width: 46vmin; height: 46vmin;
    background: radial-gradient(circle, rgba(42,24,64,0.55), transparent 66%);
    filter: blur(26px); animation: drift2 52s ease-in-out infinite;
  }
  @keyframes drift1 {
    0%,100% { transform: translate(0,0) scale(1); opacity: .8; }
    50% { transform: translate(4%, -3%) scale(1.12); opacity: 1; }
  }
  @keyframes drift2 {
    0%,100% { transform: translate(0,0) scale(1.05); opacity: .7; }
    50% { transform: translate(-5%, 4%) scale(.92); opacity: 1; }
  }

  /* ---------- WORMHOLE ---------- */
  .wh-throat {
    position: absolute; left: 50%; top: 50%; width: 18vmin; height: 18vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    background: radial-gradient(circle, #F3E6C8 10%, #E7C68B 40%, transparent 72%);
    filter: blur(6px);
  }
  .wh-ring {
    position: absolute; left: 50%; top: 50%; width: 80vmin; height: 60vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    border: 0.6vmin solid rgba(231,198,139,0.6);
    will-change: transform, opacity; animation: recede 9s linear infinite;
  }
  .wh-r2 { border-color: rgba(204,145,78,0.55); animation-delay: -2.25s; }
  .wh-r3 { border-color: rgba(204,91,58,0.5); animation-delay: -4.5s; }
  .wh-r4 { border-color: rgba(243,230,200,0.5); animation-delay: -6.75s; }
  @keyframes recede {
    0% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
    15% { opacity: .8; }
    100% { transform: translate(-50%, -50%) scale(0.08); opacity: 0; }
  }

  /* ---------- SUPERNOVA ---------- */
  .sn-core {
    position: absolute; left: 50%; top: 50%; width: 22vmin; height: 22vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    background: radial-gradient(circle, #F3E6C8 15%, #E7C68B 45%, transparent 72%);
    will-change: transform, opacity; animation: pulseCore 6s ease-in-out infinite;
  }
  .sn-rays {
    position: absolute; left: 50%; top: 50%; width: 90vmin; height: 90vmin;
    transform: translate(-50%, -50%);
    background: repeating-conic-gradient(from 0deg,
      rgba(231,198,139,0.22) 0deg 3deg, transparent 3deg 12deg);
    -webkit-mask: radial-gradient(circle, #000 6%, transparent 46%);
    mask: radial-gradient(circle, #000 6%, transparent 46%);
    will-change: transform; animation: spin 80s linear infinite;
  }
  .sn-shell {
    position: absolute; left: 50%; top: 50%; width: 30vmin; height: 30vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    border: 1vmin solid rgba(204,91,58,0.4);
    will-change: transform, opacity; animation: shell 8s ease-out infinite;
  }
  @keyframes pulseCore {
    0%,100% { transform: translate(-50%,-50%) scale(.9); opacity: .85; }
    50% { transform: translate(-50%,-50%) scale(1.1); opacity: 1; }
  }
  @keyframes shell {
    0% { transform: translate(-50%,-50%) scale(1); opacity: .6; }
    100% { transform: translate(-50%,-50%) scale(4); opacity: 0; }
  }

  /* ---------- AURORA ---------- */
  .au {
    position: absolute; top: -20%; width: 30vmin; height: 140%;
    filter: blur(18px);
    will-change: transform, opacity;
  }
  .au-1 {
    left: 18%;
    background: linear-gradient(90deg, transparent, rgba(204,145,78,0.5), transparent);
    transform: skewX(-12deg); animation: curtain1 22s ease-in-out infinite;
  }
  .au-2 {
    left: 46%;
    background: linear-gradient(90deg, transparent, rgba(231,198,139,0.45), transparent);
    transform: skewX(-12deg); animation: curtain2 28s ease-in-out infinite;
  }
  .au-3 {
    left: 70%;
    background: linear-gradient(90deg, transparent, rgba(42,24,64,0.6), transparent);
    transform: skewX(-12deg); animation: curtain1 34s ease-in-out infinite reverse;
  }
  @keyframes curtain1 {
    0%,100% { transform: skewX(-12deg) translateX(-6vmin); opacity: .55; }
    50% { transform: skewX(-12deg) translateX(6vmin) scaleY(1.05); opacity: .95; }
  }
  @keyframes curtain2 {
    0%,100% { transform: skewX(-12deg) translateX(5vmin); opacity: .9; }
    50% { transform: skewX(-12deg) translateX(-5vmin) scaleY(.95); opacity: .5; }
  }

  /* ---------- COMETS ---------- */
  .comet {
    position: absolute; width: 36vmin; height: 0.3vmin; top: 0; left: 0;
    background: linear-gradient(90deg, transparent, rgba(243,230,200,0.9));
    border-radius: 50%;
    box-shadow: 0 0 1vmin 0.1vmin rgba(231,198,139,0.5);
    will-change: transform, opacity;
  }
  .comet-1 { animation: streak1 14s linear infinite; }
  .comet-2 { animation: streak2 19s linear infinite; animation-delay: -7s; }
  .comet-3 { animation: streak1 24s linear infinite; animation-delay: -3s; }
  @keyframes streak1 {
    0% { transform: translate(-40vmin, -10vmin) rotate(28deg); opacity: 0; }
    8% { opacity: 1; }
    92% { opacity: 1; }
    100% { transform: translate(120vmin, 80vmin) rotate(28deg); opacity: 0; }
  }
  @keyframes streak2 {
    0% { transform: translate(-40vmin, 40vmin) rotate(20deg); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translate(120vmin, 110vmin) rotate(20deg); opacity: 0; }
  }

  /* ---------- ECLIPSE ---------- */
  .ec-corona {
    position: absolute; left: 50%; top: 50%; width: 44vmin; height: 44vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    background: radial-gradient(circle, transparent 40%, rgba(231,198,139,0.55) 47%, rgba(204,91,58,0.2) 56%, transparent 70%);
    will-change: transform, opacity; animation: coronaBreath 10s ease-in-out infinite;
  }
  .ec-disc {
    position: absolute; left: 50%; top: 50%; width: 36vmin; height: 36vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    background: #06060a;
    box-shadow: inset 0 0 4vmin rgba(0,0,0,0.9);
  }
  .ec-glint {
    position: absolute; left: 50%; top: 50%; width: 2.4vmin; height: 2.4vmin;
    border-radius: 50%; background: #F3E6C8;
    filter: blur(2px);
    will-change: transform, opacity;
  }
  .ec-g1 { transform: translate(7vmin, -10vmin); animation: glint 7s ease-in-out infinite; }
  .ec-g2 { transform: translate(-9vmin, 8vmin); animation: glint 9s ease-in-out infinite; animation-delay: -3s; }
  @keyframes coronaBreath {
    0%,100% { transform: translate(-50%,-50%) scale(1); opacity: .8; }
    50% { transform: translate(-50%,-50%) scale(1.06); opacity: 1; }
  }
  @keyframes glint {
    0%,100% { opacity: .2; }
    50% { opacity: 1; }
  }

  /* ---------- STARFIELD (parallax) ---------- */
  .sf-slow { animation: twinkleA 11s ease-in-out infinite, parallax 90s linear infinite; }
  .sf-mid  { animation: twinkleB 9s ease-in-out infinite, parallax 60s linear infinite; }
  .sf-fast { animation: twinkleA 7s ease-in-out infinite, parallax 38s linear infinite; }
  .sf-slow, .sf-mid, .sf-fast { will-change: transform; }
  @keyframes parallax {
    0% { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }

  /* ---------- PULSAR ---------- */
  .pl-core {
    position: absolute; left: 50%; top: 50%; width: 12vmin; height: 12vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    background: radial-gradient(circle, #F3E6C8 25%, #E7C68B 55%, transparent 75%);
    will-change: transform, opacity; animation: pulseCore 4s ease-in-out infinite;
  }
  .pl-beams {
    position: absolute; left: 50%; top: 50%; width: 140vmin; height: 140vmin;
    transform: translate(-50%, -50%);
    background:
      conic-gradient(from 0deg,
        transparent 0deg, rgba(231,198,139,0.28) 6deg, transparent 12deg,
        transparent 180deg, rgba(231,198,139,0.28) 186deg, transparent 192deg);
    -webkit-mask: radial-gradient(circle, #000 2%, rgba(0,0,0,0.4) 30%, transparent 55%);
    mask: radial-gradient(circle, #000 2%, rgba(0,0,0,0.4) 30%, transparent 55%);
    will-change: transform; animation: spin 12s linear infinite;
  }
  .pl-pulse {
    position: absolute; left: 50%; top: 50%; width: 14vmin; height: 14vmin;
    transform: translate(-50%, -50%); border-radius: 50%;
    border: 0.5vmin solid rgba(204,145,78,0.5);
    will-change: transform, opacity; animation: shell 7s ease-out infinite;
  }
  .pl-p2 { animation-delay: -3.5s; border-color: rgba(231,198,139,0.45); }

  /* ---------- REDUCED MOTION ---------- */
  @media (prefers-reduced-motion: reduce) {
    .stars, .bh-ring, .galaxy, .neb, .wh-ring, .sn-core, .sn-rays, .sn-shell,
    .au, .comet, .ec-corona, .ec-glint, .sf-slow, .sf-mid, .sf-fast,
    .pl-core, .pl-beams, .pl-pulse,
    .deep-gas-1, .deep-gas-2, .deep-gas-3, .hd-stars {
      animation: none !important;
    }
    .comet, .wh-ring, .sn-shell, .pl-pulse { opacity: .6; }
    .stars { opacity: .8; }
  }
</style>
