---
// A fixed, fully-static deep-space backdrop — gradients + a crisp star field,
// painted once and composited cheaply. Each page gets its own warm tint, but
// there is no animation, no blur and no feTurbulence here, so it costs nothing
// per frame and never makes scrolling stutter. Decorative (aria-hidden).
interface Props { variant?: string; class?: string; }
const { variant = 'starfield', class: className = '' } = Astro.props;

// --- Crisp star field (deterministic, varied size/colour/brightness) ---
const STAR_COLS = ['#FBF6EA', '#F3E6C8', '#E7C68B', '#CC914E', '#BCD0F0', '#EEEDE3'];
let s2 = 99173;
const sr = () => ((s2 = (s2 * 1103515245 + 12345) & 0x7fffffff) / 0x7fffffff);
const hdStars = Array.from({ length: 150 }, () => {
  const r = Math.pow(sr(), 2.4) * 1.5 + 0.25; // many faint, few large
  return {
    cx: +(sr() * 1000).toFixed(1),
    cy: +(sr() * 1000).toFixed(1),
    r: +r.toFixed(2),
    o: +(0.25 + sr() * 0.55).toFixed(2),
    c: STAR_COLS[(sr() * STAR_COLS.length) | 0],
  };
});
const brightStars = Array.from({ length: 7 }, () => ({
  cx: +(sr() * 1000).toFixed(1),
  cy: +(sr() * 1000).toFixed(1),
  r: +(1.3 + sr() * 1.1).toFixed(2),
}));

// Per-page warm tint — two soft static blooms give each page its own light.
const TINTS: Record<string, string> = {
  galaxy: 'rgba(231,198,139,0.10)',
  nebula: 'rgba(204,145,78,0.10)',
  wormhole: 'rgba(204,91,58,0.09)',
  supernova: 'rgba(243,230,200,0.10)',
  starfield: 'rgba(188,208,240,0.07)',
  aurora: 'rgba(231,198,139,0.09)',
};
const tint = TINTS[variant] ?? TINTS.aurora;

// Per-instance unique id so the bright-star gradient never collides.
const uid = Math.random().toString(36).slice(2, 7);
---

<div class={`cosmic absolute inset-0 overflow-hidden ${className}`} style={`--tint:${tint}`} aria-hidden="true">
  <svg class="hd-stars" viewBox="0 0 1000 1000" preserveAspectRatio="xMidYMid slice">
    <defs>
      <radialGradient id={`bs-${uid}`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.95" />
        <stop offset="35%" stop-color="#F3E6C8" stop-opacity="0.5" />
        <stop offset="100%" stop-color="#E7C68B" stop-opacity="0" />
      </radialGradient>
    </defs>
    {hdStars.map((s) => <circle cx={s.cx} cy={s.cy} r={s.r} fill={s.c} opacity={s.o} />)}
    {brightStars.map((s) => (
      <Fragment>
        <circle cx={s.cx} cy={s.cy} r={s.r * 5} fill={`url(#bs-${uid})`} />
        <circle cx={s.cx} cy={s.cy} r={s.r} fill="#ffffff" />
      </Fragment>
    ))}
  </svg>
  <div class="vignette"></div>
</div>

<style>
  .cosmic {
    background:
      radial-gradient(58% 50% at 50% 22%, var(--tint), transparent 70%),
      radial-gradient(48% 50% at 80% 78%, var(--tint), transparent 72%),
      radial-gradient(120% 100% at 50% 30%, #0c0b12 0%, #08080a 60%, #060608 100%);
  }
  .hd-stars { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.9; }
  /* Central + edge vignette keeps foreground text legible */
  .vignette {
    position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(120% 90% at 50% 50%, rgba(8,8,10,0) 42%, rgba(8,8,10,0.72) 100%),
      radial-gradient(60% 50% at 50% 46%, rgba(8,8,10,0.4), rgba(8,8,10,0) 70%);
  }
</style>
