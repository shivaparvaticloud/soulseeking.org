---
// Live-coded meditation & yoga stick figures — pure SVG + CSS, no images, no JS.
// A gentle band of figures (lotus, tree, warrior, prayer, upward-salute) breathing
// and swaying behind a soft "divine aura". Sits subtly in the background so text
// stays fully readable. Honours prefers-reduced-motion.
interface Props {
  class?: string;
  tone?: 'gold' | 'ochre';
  opacity?: number; // overall subtlety of the whole layer
}
const { class: className = '', tone = 'gold', opacity = 0.5 } = Astro.props;
const stroke = tone === 'gold' ? '#E7C68B' : '#CC914E';
const aura = tone === 'gold' ? '#E7C68B' : '#CC914E';
const uid = `med-${Math.random().toString(36).slice(2, 9)}`;

// Five distinct poses, each drawn in a 0–100 (x) by 0–120 (y) design cell.
// Lines are [x1,y1,x2,y2]; head is a small circle; everything is pure geometry.
type Pose = { head: [number, number]; lines: [number, number, number, number][] };

const poses: Pose[] = [
  // 1 — Lotus / seated meditation
  {
    head: [50, 40],
    lines: [
      [50, 47, 50, 80], // spine
      [50, 80, 30, 93], // left thigh
      [50, 80, 70, 93], // right thigh
      [33, 92, 67, 92], // crossed shins
      [50, 56, 34, 80], // left arm to knee
      [50, 56, 66, 80], // right arm to knee
    ],
  },
  // 2 — Tree pose (standing, one foot to thigh, hands in prayer overhead)
  {
    head: [50, 30],
    lines: [
      [50, 37, 50, 74], // spine
      [50, 74, 50, 110], // standing leg
      [50, 74, 36, 84], // bent thigh
      [36, 84, 50, 92], // bent shin to inner thigh
      [50, 44, 46, 16], // left arm overhead
      [50, 44, 54, 16], // right arm overhead
      [46, 16, 54, 16], // prayer hands
    ],
  },
  // 3 — Warrior II (lunge, arms extended)
  {
    head: [48, 40],
    lines: [
      [48, 47, 52, 72], // spine, slight lean
      [52, 72, 70, 90], // front thigh
      [70, 90, 70, 110], // front shin
      [52, 72, 30, 92], // back thigh
      [30, 92, 22, 110], // back shin
      [50, 54, 76, 48], // front arm
      [50, 54, 24, 54], // back arm
    ],
  },
  // 4 — Standing prayer (Tadasana, hands at heart)
  {
    head: [50, 32],
    lines: [
      [50, 39, 50, 78], // spine
      [50, 78, 44, 112], // left leg
      [50, 78, 56, 112], // right leg
      [50, 50, 44, 60], // left forearm to chest
      [50, 50, 56, 60], // right forearm to chest
      [44, 60, 56, 60], // hands meeting
    ],
  },
  // 5 — Upward salute (Urdhva Hastasana, arms raised in a V)
  {
    head: [50, 32],
    lines: [
      [50, 39, 50, 78], // spine
      [50, 78, 44, 112], // left leg
      [50, 78, 56, 112], // right leg
      [50, 46, 30, 20], // left arm raised
      [50, 46, 70, 20], // right arm raised
    ],
  },
];

const VW = 1200;
const VH = 220;
const slot = VW / poses.length;
---

<div
  class={`pointer-events-none select-none ${className}`}
  style={`opacity:${opacity}`}
  aria-hidden="true"
>
  <svg
    viewBox={`0 0 ${VW} ${VH}`}
    width="100%"
    height="100%"
    fill="none"
    preserveAspectRatio="xMidYMid slice"
    class="block h-full w-full"
  >
    <defs>
      <radialGradient id={`${uid}-glow`} cx="50%" cy="46%" r="55%">
        <stop offset="0%" stop-color={aura} stop-opacity="0.55"></stop>
        <stop offset="45%" stop-color={aura} stop-opacity="0.18"></stop>
        <stop offset="100%" stop-color={aura} stop-opacity="0"></stop>
      </radialGradient>
      <radialGradient id={`${uid}-field`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color={aura} stop-opacity="0.16"></stop>
        <stop offset="100%" stop-color={aura} stop-opacity="0"></stop>
      </radialGradient>
    </defs>

    <!-- the divine aura rising from behind the figures -->
    <rect class="ss-field" width={VW} height={VH} fill={`url(#${uid}-field)`}></rect>

    {
      poses.map((p, i) => {
        const cx = slot * i + slot / 2;
        return (
          <g
            class="ss-fig"
            style={`--d:${(i * 0.9).toFixed(2)}s`}
            transform={`translate(${cx - 50} 52)`}
          >
            <circle class="ss-aura" cx="50" cy="56" r="74" fill={`url(#${uid}-glow)`} />
            <g
              stroke={stroke}
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx={p.head[0]} cy={p.head[1]} r="7" />
              {p.lines.map((l) => (
                <line x1={l[0]} y1={l[1]} x2={l[2]} y2={l[3]} />
              ))}
            </g>
          </g>
        );
      })
    }
  </svg>
</div>

<style>
  .ss-fig {
    transform-box: fill-box;
    transform-origin: 50% 100%;
    animation: ss-live 7s ease-in-out infinite;
    animation-delay: var(--d);
    will-change: transform;
  }
  .ss-aura {
    transform-box: fill-box;
    transform-origin: 50% 50%;
    animation: ss-breathe 6s ease-in-out infinite;
    animation-delay: var(--d);
  }
  .ss-field {
    transform-box: fill-box;
    transform-origin: 50% 50%;
    animation: ss-field 11s ease-in-out infinite;
  }

  /* gentle float + faint 3d-ish sway, all subtle */
  @keyframes ss-live {
    0%,
    100% {
      transform: translateY(0) scaleX(1);
    }
    50% {
      transform: translateY(-7px) scaleX(0.975);
    }
  }
  @keyframes ss-breathe {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(1);
    }
    50% {
      opacity: 0.9;
      transform: scale(1.08);
    }
  }
  @keyframes ss-field {
    0%,
    100% {
      opacity: 0.6;
    }
    50% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ss-fig,
    .ss-aura,
    .ss-field {
      animation: none;
    }
  }
</style>
