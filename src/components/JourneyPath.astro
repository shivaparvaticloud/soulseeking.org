---
// A meandering "journey path" course map (PDF p.24): a winding trail with
// numbered waystations, one per module. Pure SVG, generated from the labels.
interface Props {
  stations: string[];
  class?: string;
}
const { stations, class: className = '' } = Astro.props;

const W = 1000;
const rowH = 150;
const H = Math.max(rowH * stations.length * 0.62 + 120, 360);
const gold = '#E7C68B';
const ochre = '#CC914E';
const earth = '#604C44';

// lay the stations in a vertical serpentine
const pts = stations.map((_, i) => {
  const y = 70 + i * ((H - 140) / Math.max(stations.length - 1, 1));
  const x = i % 2 === 0 ? W * 0.28 : W * 0.72;
  return { x, y };
});

// build a smooth path through the points
let d = `M ${pts[0].x} ${pts[0].y}`;
for (let i = 1; i < pts.length; i++) {
  const prev = pts[i - 1];
  const cur = pts[i];
  const midY = (prev.y + cur.y) / 2;
  d += ` C ${prev.x} ${midY}, ${cur.x} ${midY}, ${cur.x} ${cur.y}`;
}
---

<svg
  viewBox={`0 0 ${W} ${H}`}
  width="100%"
  style="height:auto"
  fill="none"
  role="img"
  aria-label="Course journey map"
  class={className}
>
  <path d={d} stroke={ochre} stroke-width="1.4" stroke-dasharray="2 7" stroke-linecap="round" opacity="0.7" />
  {
    pts.map((p, i) => (
      <g>
        <circle cx={p.x} cy={p.y} r="20" fill="#EEEDE3" stroke={gold} stroke-width="1.4" />
        <circle cx={p.x} cy={p.y} r="26" fill="none" stroke={ochre} stroke-width="0.5" opacity="0.5" />
        <text
          x={p.x}
          y={p.y + 5}
          text-anchor="middle"
          font-size="16"
          font-family="'EB Garamond', Georgia, serif"
          fill={earth}
        >
          {i + 1}
        </text>
        <text
          x={i % 2 === 0 ? p.x + 40 : p.x - 40}
          y={p.y + 5}
          text-anchor={i % 2 === 0 ? 'start' : 'end'}
          font-size="17"
          letter-spacing="2"
          font-family="'EB Garamond', Georgia, serif"
          fill={earth}
        >
          {stations[i]}
        </text>
      </g>
    ))
  }
</svg>
