---
// A Voyager-style pulsar map (PDF p.18): lines radiating from a point,
// each annotated with binary tick marks. Our cosmic "you are here".
interface Props {
  size?: number;
  tone?: 'gold' | 'ochre';
  class?: string;
}
const { size = 320, tone = 'gold', class: className = '' } = Astro.props;
const stroke = tone === 'gold' ? '#E7C68B' : '#CC914E';

const cx = 50;
const cy = 50;
// deterministic pseudo-random so the build is stable
let seed = 7;
const rnd = () => {
  seed = (seed * 1103515245 + 12345) % 2147483648;
  return seed / 2147483648;
};

type Spoke = { x2: number; y2: number; ticks: { x: number; y: number }[] };
const spokes: Spoke[] = [];
const n = 12;
for (let i = 0; i < n; i++) {
  const a = (i / n) * Math.PI * 2 + rnd() * 0.18;
  const len = 26 + rnd() * 20;
  const x2 = cx + len * Math.cos(a);
  const y2 = cy + len * Math.sin(a);
  // tick marks (binary period) along the spoke
  const ticks: { x: number; y: number }[] = [];
  const tcount = 3 + ((rnd() * 4) | 0);
  const nx = Math.cos(a + Math.PI / 2);
  const ny = Math.sin(a + Math.PI / 2);
  for (let k = 1; k <= tcount; k++) {
    const f = k / (tcount + 1);
    const px = cx + len * f * Math.cos(a);
    const py = cy + len * f * Math.sin(a);
    ticks.push({ x: px + nx * 1.6, y: py + ny * 1.6 });
  }
  spokes.push({ x2, y2, ticks });
}
---

<svg
  viewBox="0 0 100 100"
  width={size}
  height={size}
  fill="none"
  role="img"
  aria-label="Pulsar direction map"
  class={className}
>
  <g stroke={stroke} stroke-width="0.5" stroke-linecap="round">
    {
      spokes.map((s) => (
        <>
          <line x1={cx} y1={cy} x2={s.x2} y2={s.y2} opacity="0.7" />
          {s.ticks.map((t) => (
            <circle cx={t.x} cy={t.y} r="0.7" fill={stroke} stroke="none" opacity="0.85" />
          ))}
        </>
      ))
    }
  </g>
  <circle cx={cx} cy={cy} r="2.4" fill={stroke} />
  <circle cx={cx} cy={cy} r="6" stroke={stroke} stroke-width="0.4" opacity="0.5" />
</svg>
