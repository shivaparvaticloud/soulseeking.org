---
// BrandArt: one of 10 coded decorative "artworks" chosen by `variant`.
// Fine-detail, hand-of-a-human brand imagery inspired by Aboriginal dot-paintings,
// etched landscapes, gold-stipple cloth and grunge stone. Pure inline SVG + CSS.
// No raster images, no external requests, no JS. Static decorative panels meant to
// overlay the site's dark canvas at low opacity (the SVG itself is mostly transparent).
interface Props {
  variant?: string;
  class?: string;
}
const { variant = 'dotcircles', class: className = '' } = Astro.props;
const uid = Math.random().toString(36).slice(2, 7);

// ---- palette -------------------------------------------------------------
const GOLD = '#E7C68B';
const OCHRE = '#CC914E';
const PALE = '#F3E6C8';
const OXBLOOD = '#692828';
const PAL = [GOLD, OCHRE, PALE, GOLD, OCHRE];

// deterministic pseudo-random so output is stable per render but varied
let seed = 1337;
const rnd = () => {
  seed = (seed * 1103515245 + 12345) & 0x7fffffff;
  return seed / 0x7fffffff;
};
const rr = (a: number, b: number) => a + rnd() * (b - a);
const pick = <T,>(arr: T[]) => arr[Math.floor(rnd() * arr.length)];

// =====================================================================
// 1. dotcircles — dense field of concentric-circle motifs, dotted strokes
// =====================================================================
type Ring = { cx: number; cy: number; r: number; c: string; o: number };
const dotcircles: Ring[] = [];
for (let i = 0; i < 26; i++) {
  const cx = rr(10, 390);
  const cy = rr(10, 390);
  const base = rr(8, 34);
  const rings = 2 + Math.floor(rnd() * 4);
  const col = pick(PAL);
  for (let k = 0; k < rings; k++) {
    dotcircles.push({ cx, cy, r: base - k * (base / (rings + 0.6)), c: col, o: rr(0.35, 0.7) });
  }
  dotcircles.push({ cx, cy, r: 1.1, c: OXBLOOD, o: 0.6 }); // center dot
}

// =====================================================================
// 2. maze — interlocking concentric-square fields, dotted strokes
// =====================================================================
type Sq = { x: number; y: number; s: number; c: string; o: number };
const maze: Sq[] = [];
for (let gx = 0; gx < 5; gx++) {
  for (let gy = 0; gy < 5; gy++) {
    const cx = 40 + gx * 80 + rr(-8, 8);
    const cy = 40 + gy * 80 + rr(-8, 8);
    const big = rr(26, 38);
    const steps = 3 + Math.floor(rnd() * 3);
    const col = pick(PAL);
    for (let k = 0; k < steps; k++) {
      const s = big - k * (big / (steps + 0.5));
      maze.push({ x: cx - s, y: cy - s, s: s * 2, c: col, o: rr(0.35, 0.7) });
    }
  }
}

// =====================================================================
// 3. songlines — flowing horizontal contour lines, dotted texture between
// =====================================================================
const songlines: { d: string; c: string; o: number; dash: boolean }[] = [];
for (let i = 0; i < 22; i++) {
  const y = i * 19 + rr(-4, 4);
  const amp = rr(6, 22);
  const ph = rr(0, 6.28);
  let d = `M -20 ${y.toFixed(1)}`;
  for (let x = 0; x <= 420; x += 28) {
    const yy = y + Math.sin(x / 60 + ph) * amp;
    d += ` L ${x} ${yy.toFixed(1)}`;
  }
  songlines.push({ d, c: pick(PAL), o: rr(0.4, 0.75), dash: i % 2 === 1 });
}

// =====================================================================
// 4. waterholes — concentric circles + travelling lines + U-shapes (people)
// =====================================================================
const whNodes: { cx: number; cy: number }[] = [];
for (let i = 0; i < 7; i++) whNodes.push({ cx: rr(50, 350), cy: rr(50, 350) });
const whRings: Ring[] = [];
for (const n of whNodes) {
  const rings = 3 + Math.floor(rnd() * 3);
  const col = pick(PAL);
  for (let k = 0; k < rings; k++) whRings.push({ cx: n.cx, cy: n.cy, r: 6 + k * 7, c: col, o: rr(0.4, 0.7) });
  whRings.push({ cx: n.cx, cy: n.cy, r: 1.2, c: OXBLOOD, o: 0.6 });
}
const whLinks: { x1: number; y1: number; x2: number; y2: number; c: string }[] = [];
for (let i = 0; i < whNodes.length - 1; i++) {
  whLinks.push({ x1: whNodes[i].cx, y1: whNodes[i].cy, x2: whNodes[i + 1].cx, y2: whNodes[i + 1].cy, c: pick(PAL) });
}
const whPeople: { d: string; c: string }[] = [];
for (let i = 0; i < 14; i++) {
  const cx = rr(20, 380);
  const cy = rr(20, 380);
  const w = rr(6, 11);
  const h = rr(7, 13);
  whPeople.push({ d: `M ${cx - w} ${cy - h} L ${cx - w} ${cy} A ${w} ${w} 0 0 0 ${cx + w} ${cy} L ${cx + w} ${cy - h}`, c: pick(PAL) });
}

// =====================================================================
// 5. stipple — hundreds of tiny dots following curved flow lines
// =====================================================================
const stipple: { cx: number; cy: number; r: number; c: string; o: number }[] = [];
for (let line = 0; line < 16; line++) {
  const baseY = line * 26 + rr(-6, 6);
  const amp = rr(10, 28);
  const ph = rr(0, 6.28);
  const col = pick(PAL);
  for (let x = -10; x <= 410; x += rr(7, 12)) {
    const y = baseY + Math.sin(x / 55 + ph) * amp;
    stipple.push({ cx: x + rr(-2, 2), cy: y + rr(-2, 2), r: rr(0.5, 1.3), c: col, o: rr(0.3, 0.75) });
  }
}

// =====================================================================
// 6. ridges — nested topographic ridge contours (offset concentric blobs)
// =====================================================================
const ridges: { d: string; c: string; o: number }[] = [];
for (let g = 0; g < 4; g++) {
  const cx = rr(80, 320);
  const cy = rr(80, 320);
  const col = pick(PAL);
  const ox = rr(-2, 2);
  const oy = rr(-2, 2);
  const pts = 10;
  const wob = Array.from({ length: pts }, () => rr(0.78, 1.2));
  for (let ring = 0; ring < 9; ring++) {
    const rad = 14 + ring * 16;
    let d = '';
    for (let p = 0; p <= pts; p++) {
      const a = (p / pts) * Math.PI * 2;
      const w = wob[p % pts];
      const x = cx + ox * ring + Math.cos(a) * rad * w;
      const y = cy + oy * ring + Math.sin(a) * rad * w * 0.82;
      d += (p === 0 ? 'M' : 'L') + ` ${x.toFixed(1)} ${y.toFixed(1)}`;
    }
    ridges.push({ d: d + ' Z', c: col, o: rr(0.32, 0.62) });
  }
}

// =====================================================================
// 7. lacework — delicate filigree of fine arcs + tiny dots
// =====================================================================
const laceArcs: { d: string; c: string; o: number }[] = [];
const laceDots: { cx: number; cy: number; c: string; o: number }[] = [];
for (let gy = 0; gy < 6; gy++) {
  for (let gx = 0; gx < 6; gx++) {
    const cx = 35 + gx * 66;
    const cy = 35 + gy * 66;
    const r = rr(14, 22);
    const col = pick(PAL);
    // four petal arcs
    for (let q = 0; q < 4; q++) {
      const a0 = (q / 4) * Math.PI * 2;
      const a1 = a0 + Math.PI / 2;
      const x0 = cx + Math.cos(a0) * r;
      const y0 = cy + Math.sin(a0) * r;
      const x1 = cx + Math.cos(a1) * r;
      const y1 = cy + Math.sin(a1) * r;
      laceArcs.push({ d: `M ${x0.toFixed(1)} ${y0.toFixed(1)} A ${r} ${r} 0 0 1 ${x1.toFixed(1)} ${y1.toFixed(1)}`, c: col, o: rr(0.4, 0.7) });
    }
    laceDots.push({ cx, cy, c: OXBLOOD, o: 0.55 });
    for (let d = 0; d < 8; d++) {
      const a = (d / 8) * Math.PI * 2;
      laceDots.push({ cx: cx + Math.cos(a) * (r + 4), cy: cy + Math.sin(a) * (r + 4), c: col, o: rr(0.4, 0.7) });
    }
  }
}

// =====================================================================
// 8. weave — concentric rounded squares nested, woven offset grid
// =====================================================================
const weave: { x: number; y: number; s: number; rx: number; c: string; o: number }[] = [];
for (let gy = 0; gy < 5; gy++) {
  for (let gx = 0; gx < 5; gx++) {
    const cx = 40 + gx * 80 + (gy % 2 ? 20 : 0);
    const cy = 40 + gy * 80;
    const big = rr(28, 36);
    const col = pick(PAL);
    const steps = 4;
    for (let k = 0; k < steps; k++) {
      const s = big - k * (big / (steps + 0.4));
      weave.push({ x: cx - s, y: cy - s, s: s * 2, rx: s * 0.45, c: col, o: rr(0.34, 0.66) });
    }
  }
}

// =====================================================================
// 9. radiance — radial sunburst of fine dotted rays + concentric rings
// =====================================================================
const RC = 200;
const radRays: { x2: number; y2: number; c: string; o: number }[] = [];
const rays = 72;
for (let i = 0; i < rays; i++) {
  const a = (i / rays) * Math.PI * 2;
  const len = rr(150, 290);
  radRays.push({ x2: RC + Math.cos(a) * len, y2: RC + Math.sin(a) * len, c: pick(PAL), o: rr(0.25, 0.6) });
}
const radRings: Ring[] = [];
for (let k = 0; k < 12; k++) radRings.push({ cx: RC, cy: RC, r: 16 + k * 17, c: pick(PAL), o: rr(0.3, 0.6) });
radRings.push({ cx: RC, cy: RC, r: 2.2, c: OXBLOOD, o: 0.7 });

// =====================================================================
// 10. terrain — dense parallel hatching bending around soft forms
// =====================================================================
const terrain: { d: string; c: string; o: number }[] = [];
const forms = [
  { cx: 130, cy: 150, r: 90 },
  { cx: 290, cy: 270, r: 110 },
];
for (let i = 0; i < 60; i++) {
  const y = i * 7 - 4;
  let d = `M -10 ${y}`;
  for (let x = 0; x <= 410; x += 10) {
    let yy = y;
    for (const f of forms) {
      const dx = x - f.cx;
      const dist = Math.abs(yy - f.cy) + Math.abs(dx) * 0.4;
      if (dist < f.r) {
        const bend = (1 - dist / f.r) * 22 * Math.sign(yy - f.cy || 1);
        yy += bend * (1 - Math.abs(dx) / (f.r + 40));
      }
    }
    d += ` L ${x} ${yy.toFixed(1)}`;
  }
  terrain.push({ d, c: i % 7 === 0 ? OCHRE : GOLD, o: rr(0.28, 0.55) });
}
---

<svg
  width="100%"
  height="100%"
  viewBox="0 0 400 400"
  preserveAspectRatio="xMidYMid slice"
  role="img"
  aria-hidden="true"
  class={className}
  fill="none"
>
  {variant === 'dotcircles' && (
    <g stroke-dasharray="1 5" stroke-linecap="round">
      {dotcircles.map((r) =>
        r.r < 2 ? (
          <circle cx={r.cx} cy={r.cy} r={r.r} fill={r.c} stroke="none" opacity={r.o} />
        ) : (
          <circle cx={r.cx} cy={r.cy} r={r.r} stroke={r.c} stroke-width="1.1" opacity={r.o} />
        )
      )}
    </g>
  )}

  {variant === 'maze' && (
    <g stroke-dasharray="1 4" stroke-linecap="round" fill="none">
      {maze.map((s) => (
        <rect x={s.x} y={s.y} width={s.s} height={s.s} stroke={s.c} stroke-width="1.1" opacity={s.o} />
      ))}
    </g>
  )}

  {variant === 'songlines' && (
    <g fill="none" stroke-linecap="round">
      {songlines.map((l) => (
        <path
          d={l.d}
          stroke={l.c}
          stroke-width={l.dash ? 0.9 : 1.3}
          stroke-dasharray={l.dash ? '1 4' : undefined}
          opacity={l.o}
        />
      ))}
    </g>
  )}

  {variant === 'waterholes' && (
    <g fill="none" stroke-linecap="round">
      {whLinks.map((l) => (
        <line x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2} stroke={l.c} stroke-width="1" stroke-dasharray="1 4" opacity="0.5" />
      ))}
      {whRings.map((r) =>
        r.r < 2 ? (
          <circle cx={r.cx} cy={r.cy} r={r.r} fill={r.c} stroke="none" opacity={r.o} />
        ) : (
          <circle cx={r.cx} cy={r.cy} r={r.r} stroke={r.c} stroke-width="1.1" stroke-dasharray="1 4" opacity={r.o} />
        )
      )}
      {whPeople.map((p) => (
        <path d={p.d} stroke={p.c} stroke-width="1.2" stroke-dasharray="1 3" opacity="0.6" />
      ))}
    </g>
  )}

  {variant === 'stipple' && (
    <g stroke="none">
      {stipple.map((d) => (
        <circle cx={d.cx} cy={d.cy} r={d.r} fill={d.c} opacity={d.o} />
      ))}
    </g>
  )}

  {variant === 'ridges' && (
    <g fill="none" stroke-linejoin="round">
      {ridges.map((r) => (
        <path d={r.d} stroke={r.c} stroke-width="1" opacity={r.o} />
      ))}
    </g>
  )}

  {variant === 'lacework' && (
    <g fill="none" stroke-linecap="round">
      {laceArcs.map((a) => (
        <path d={a.d} stroke={a.c} stroke-width="0.8" opacity={a.o} />
      ))}
      {laceDots.map((d) => (
        <circle cx={d.cx} cy={d.cy} r="1" fill={d.c} opacity={d.o} />
      ))}
    </g>
  )}

  {variant === 'weave' && (
    <g fill="none" stroke-linejoin="round">
      {weave.map((w) => (
        <rect x={w.x} y={w.y} width={w.s} height={w.s} rx={w.rx} ry={w.rx} stroke={w.c} stroke-width="1.1" stroke-dasharray="1 4" opacity={w.o} />
      ))}
    </g>
  )}

  {variant === 'radiance' && (
    <g stroke-linecap="round">
      {radRays.map((r) => (
        <line x1={RC} y1={RC} x2={r.x2} y2={r.y2} stroke={r.c} stroke-width="0.9" stroke-dasharray="1 5" opacity={r.o} />
      ))}
      {radRings.map((r) =>
        r.r < 3 ? (
          <circle cx={r.cx} cy={r.cy} r={r.r} fill={r.c} stroke="none" opacity={r.o} />
        ) : (
          <circle cx={r.cx} cy={r.cy} r={r.r} fill="none" stroke={r.c} stroke-width="1" stroke-dasharray="1 5" opacity={r.o} />
        )
      )}
    </g>
  )}

  {variant === 'terrain' && (
    <g fill="none" stroke-linecap="round">
      {terrain.map((t) => (
        <path d={t.d} stroke={t.c} stroke-width="1" opacity={t.o} />
      ))}
    </g>
  )}
</svg>
