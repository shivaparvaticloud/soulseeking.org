---
// Twinkling cosmos rendered on a <canvas> with deterministic math.
// No image assets; respects reduced-motion. Config passed via data-* so the
// script can be a bundled module (no inline script → stricter CSP).
interface Props {
  class?: string;
  density?: number; // stars per 10,000 px^2
}
const { class: className = '', density = 1.1 } = Astro.props;
---

<canvas
  class={`block h-full w-full ${className}`}
  data-starfield
  data-density={density}
  aria-hidden="true"></canvas>

<script>
  function initStarfields() {
    document.querySelectorAll('canvas[data-starfield]').forEach((canvas) => {
      const el = canvas as HTMLCanvasElement;
      if (el.dataset.bound === '1' || !el.getContext) return;
      el.dataset.bound = '1';
      const density = parseFloat(el.dataset.density || '1.1') || 1.1;
      const ctx = el.getContext('2d');
      if (!ctx) return;
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let stars: { x: number; y: number; r: number; phase: number; speed: number; color: string }[] = [];
      let raf: number | null = null;
      let w = 0;
      let h = 0;
      const palette = ['#E7C68B', '#EEEDE3', '#CC914E', '#FBF6EA'];

      function seed() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        w = el.clientWidth;
        h = el.clientHeight;
        el.width = Math.floor(w * dpr);
        el.height = Math.floor(h * dpr);
        ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
        const count = Math.max(40, Math.floor(((w * h) / 10000) * density));
        stars = [];
        for (let i = 0; i < count; i++) {
          stars.push({
            x: Math.random() * w,
            y: Math.random() * h,
            r: Math.random() * 1.4 + 0.3,
            phase: Math.random() * Math.PI * 2,
            speed: Math.random() * 0.9 + 0.25,
            color: palette[(Math.random() * palette.length) | 0],
          });
        }
      }

      function draw(t: number) {
        ctx!.clearRect(0, 0, w, h);
        for (const s of stars) {
          const tw = reduce ? 0.7 : 0.5 + 0.5 * Math.sin(t * 0.001 * s.speed + s.phase);
          ctx!.globalAlpha = 0.25 + 0.75 * tw;
          ctx!.beginPath();
          ctx!.arc(s.x, s.y, s.r, 0, Math.PI * 2);
          ctx!.fillStyle = s.color;
          ctx!.fill();
        }
        ctx!.globalAlpha = 1;
        if (!reduce) raf = requestAnimationFrame(draw);
      }

      function start() {
        seed();
        if (raf) cancelAnimationFrame(raf);
        if (reduce) draw(0);
        else raf = requestAnimationFrame(draw);
      }

      let resizeTimer: number | null = null;
      window.addEventListener('resize', () => {
        if (resizeTimer) clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(start, 200);
      });
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            if (!raf && !reduce) raf = requestAnimationFrame(draw);
          } else if (raf) {
            cancelAnimationFrame(raf);
            raf = null;
          }
        }
      });
      io.observe(el);
      start();
    });
  }

  initStarfields();
  document.addEventListener('astro:page-load', initStarfields);
</script>
