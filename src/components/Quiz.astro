---
import type { QuizQuestion } from '../lib/parser';
interface Props {
  questions: QuizQuestion[];
  title?: string;
  kicker?: string;
}
const { questions, title = 'Consolidate Your Learning', kicker = 'Quiz' } = Astro.props;
if (!questions.length) return null;
const id = `quiz-${Math.random().toString(36).slice(2, 9)}`;
---

<section class="my-phi-2 card-soul p-phi-2" data-quiz id={id}>
  <p class="accent text-gold">{kicker}</p>
  <h3 class="mt-2 display-lg text-2xl text-mist">{title}</h3>

  <ol class="mt-phi-1 space-y-phi-2">
    {
      questions.map((q, qi) => (
        <li class="quiz-q" data-answered="false">
          <p class="font-serif text-lg text-mist/85">
            <span class="mr-2 text-gold">{qi + 1}.</span>
            <span set:html={q.q} />
          </p>
          <div class="mt-3 grid gap-2" role="group" aria-label={`Question ${qi + 1}`}>
            {q.options.map((opt) => (
              <button
                type="button"
                class="quiz-opt group flex items-center gap-3 rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 text-left text-mist/85 transition-phi hover:border-gold hover:bg-gold/10"
                data-correct={opt.correct ? 'true' : 'false'}
              >
                <span class="quiz-mark inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-gold/40 text-xs" aria-hidden="true" />
                <span set:html={opt.text} />
              </button>
            ))}
          </div>
          {q.explain && (
            <p class="quiz-explain mt-3 hidden border-l-2 border-gold/60 pl-4 font-serif text-sm italic text-mist/70" set:html={q.explain} />
          )}
        </li>
      ))
    }
  </ol>

  <p class="quiz-score mt-phi-2 text-center accent text-gold" aria-live="polite" data-total={questions.length}>
    Answered 0 of {questions.length}
  </p>
</section>

<script>
  document.querySelectorAll('[data-quiz]').forEach((quiz) => {
    const scoreEl = quiz.querySelector('.quiz-score') as HTMLElement | null;
    const total = scoreEl ? parseInt(scoreEl.dataset.total || '0', 10) : 0;
    let answered = 0;
    let correct = 0;

    quiz.querySelectorAll('.quiz-q').forEach((qEl) => {
      const opts = qEl.querySelectorAll<HTMLButtonElement>('.quiz-opt');
      opts.forEach((btn) => {
        btn.addEventListener('click', () => {
          if (qEl.getAttribute('data-answered') === 'true') return;
          qEl.setAttribute('data-answered', 'true');
          const isCorrect = btn.dataset.correct === 'true';
          answered += 1;
          if (isCorrect) correct += 1;

          opts.forEach((o) => {
            o.disabled = true;
            const mark = o.querySelector('.quiz-mark') as HTMLElement | null;
            if (o.dataset.correct === 'true') {
              o.classList.add('border-ochre', 'bg-gold/20');
              if (mark) {
                mark.textContent = '\u2713';
                mark.classList.add('bg-ochre', 'text-cream', 'border-ochre');
              }
            } else if (o === btn) {
              o.classList.add('border-oxblood', 'bg-oxblood/10', 'opacity-80');
              if (mark) {
                mark.textContent = '\u2717';
                mark.classList.add('border-oxblood', 'text-oxblood');
              }
            } else {
              o.classList.add('opacity-50');
            }
          });

          const explain = qEl.querySelector('.quiz-explain');
          if (explain) explain.classList.remove('hidden');

          if (scoreEl) {
            if (answered === total) {
              scoreEl.textContent = `You scored ${correct} of ${total}`;
            } else {
              scoreEl.textContent = `Answered ${answered} of ${total} \u00b7 ${correct} correct`;
            }
          }
        });
      });
    });
  });
</script>
