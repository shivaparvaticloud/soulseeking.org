---
// The home page's living background: a fixed field of stars and emerging divine
// light with a slowly rotating five-layer mandala. It stays put while the text
// scrolls over it. Pure SVG/CSS over the shared canvas — no images. Decorative
// (aria-hidden); every animation stills under reduced-motion / Motion-off.
import Starfield from './Starfield.astro';

const C = 500; // viewBox centre
// ---- layer 1: outer ring of ticks ----
const ticks = Array.from({ length: 72 }, (_, i) => {
  const a = (i / 72) * Math.PI * 2;
  const r1 = 472, r2 = i % 6 === 0 ? 448 : 460;
  return {
    x1: C + Math.cos(a) * r1, y1: C + Math.sin(a) * r1,
    x2: C + Math.cos(a) * r2, y2: C + Math.sin(a) * r2,
    big: i % 6 === 0,
  };
});
// ---- layer 2: lotus petals ----
const petals = Array.from({ length: 24 }, (_, i) => {
  const a = (i / 24) * Math.PI * 2;
  const tip = 415, base = 300, w = 0.11;
  const tx = C + Math.cos(a) * tip, ty = C + Math.sin(a) * tip;
  const lx = C + Math.cos(a - w) * base, ly = C + Math.sin(a - w) * base;
  const rx = C + Math.cos(a + w) * base, ry = C + Math.sin(a + w) * base;
  const cl = C + Math.cos(a - w * 0.5) * ((tip + base) / 2);
  const clY = C + Math.sin(a - w * 0.5) * ((tip + base) / 2);
  const cr = C + Math.cos(a + w * 0.5) * ((tip + base) / 2);
  const crY = C + Math.sin(a + w * 0.5) * ((tip + base) / 2);
  return `M${lx.toFixed(1)} ${ly.toFixed(1)} Q${cl.toFixed(1)} ${clY.toFixed(1)} ${tx.toFixed(1)} ${ty.toFixed(1)} Q${cr.toFixed(1)} ${crY.toFixed(1)} ${rx.toFixed(1)} ${ry.toFixed(1)}`;
});
// ---- layer 3: a 12-point star (dodecagram, {12/5}) ----
const star = (() => {
  const pts: string[] = [];
  const n = 12, step = 5, r = 260;
  let idx = 0;
  for (let k = 0; k < n; k++) {
    const a = (idx / n) * Math.PI * 2 - Math.PI / 2;
    pts.push(`${(C + Math.cos(a) * r).toFixed(1)} ${(C + Math.sin(a) * r).toFixed(1)}`);
    idx = (idx + step) % n;
  }
  return pts.join(' ');
})();
// ---- layer 4: radial spokes ----
const spokes = Array.from({ length: 24 }, (_, i) => {
  const a = (i / 24) * Math.PI * 2;
  return {
    x1: C + Math.cos(a) * 150, y1: C + Math.sin(a) * 150,
    x2: C + Math.cos(a) * 205, y2: C + Math.sin(a) * 205,
  };
});
// ---- layer 5: seed of life ----
const seed = Array.from({ length: 6 }, (_, i) => {
  const a = (i / 6) * Math.PI * 2;
  return { cx: C + Math.cos(a) * 55, cy: C + Math.sin(a) * 55 };
});
---

<div class="home-atmos pointer-events-none fixed inset-0 z-0 overflow-hidden" aria-hidden="true">
  <Starfield class="absolute inset-0 h-full w-full" density={1.5} />

  <!-- emerging divine light -->
  <div class="home-light"></div>

  <!-- rotating five-layer mandala -->
  <div class="home-mandala">
    <svg viewBox="0 0 1000 1000" width="100%" height="100%" fill="none" role="presentation">
      <g class="m-layer m-cw" style="animation-duration:150s" stroke="#E7C68B">
        {ticks.map((t) => (
          <line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} stroke-width={t.big ? 1.6 : 0.8} opacity={t.big ? 0.6 : 0.32} />
        ))}
        <circle cx={C} cy={C} r="440" stroke-width="0.6" opacity="0.28" />
      </g>

      <g class="m-layer m-ccw" style="animation-duration:115s" stroke="#E7C68B" stroke-width="1" opacity="0.4">
        {petals.map((d) => <path d={d} />)}
      </g>

      <g class="m-layer m-cw" style="animation-duration:200s" stroke="#CC914E">
        <polygon points={star} stroke-width="1" opacity="0.4" />
        <circle cx={C} cy={C} r="260" stroke="#E7C68B" stroke-width="0.6" opacity="0.22" />
      </g>

      <g class="m-layer m-ccw" style="animation-duration:90s" stroke="#E7C68B" opacity="0.45">
        {spokes.map((s) => <line x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2} stroke-width="0.8" />)}
        <circle cx={C} cy={C} r="150" stroke-width="0.7" opacity="0.6" />
        <circle cx={C} cy={C} r="205" stroke-width="0.5" opacity="0.4" />
      </g>

      <g class="m-layer m-cw" style="animation-duration:170s" stroke="#F3E6C8" stroke-width="0.8" opacity="0.5">
        <circle cx={C} cy={C} r="55" />
        {seed.map((s) => <circle cx={s.cx} cy={s.cy} r="55" />)}
      </g>
    </svg>
  </div>
</div>

<style>
  .home-atmos { contain: strict; }

  /* central light that breathes */
  .home-light {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 78vmin;
    height: 78vmin;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(247, 240, 214, 0.2) 0%,
      rgba(231, 198, 139, 0.12) 28%,
      rgba(204, 145, 78, 0.05) 55%,
      transparent 74%
    );
    animation: atmos-breathe 11s var(--ease-soul, ease) infinite;
  }

  .home-mandala {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 128vmin;
    height: 128vmin;
    transform: translate(-50%, -50%);
    opacity: 0.92;
    -webkit-mask-image: radial-gradient(circle at center, transparent 3%, #000 13%, #000 82%, transparent 100%);
    mask-image: radial-gradient(circle at center, transparent 3%, #000 13%, #000 82%, transparent 100%);
  }

  .m-layer { transform-box: view-box; transform-origin: center; }
  .m-cw { animation: atmos-spin 1s linear infinite; }
  .m-ccw { animation: atmos-spin 1s linear infinite; animation-direction: reverse; }

  @keyframes atmos-spin { to { transform: rotate(360deg); } }
  @keyframes atmos-breathe {
    0%, 100% { opacity: 0.85; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-light { animation: none; }
    .m-cw, .m-ccw { animation: none; }
  }
</style>
