---
// The home page's living background: a fixed field of stars and emerging divine
// light with a slowly rotating five-layer mandala. It stays put while the text
// scrolls over it. Pure SVG/CSS over the shared canvas — no images. Decorative
// (aria-hidden); every animation stills under reduced-motion / Motion-off.
import Starfield from './Starfield.astro';

const C = 500; // viewBox centre
// ---- layer 1: outer ring of ticks ----
const ticks = Array.from({ length: 72 }, (_, i) => {
  const a = (i / 72) * Math.PI * 2;
  const r1 = 472, r2 = i % 6 === 0 ? 448 : 460;
  return {
    x1: C + Math.cos(a) * r1, y1: C + Math.sin(a) * r1,
    x2: C + Math.cos(a) * r2, y2: C + Math.sin(a) * r2,
    big: i % 6 === 0,
  };
});
// ---- layer 2: a 12-point star (dodecagram, {12/5}) ----
const star = (() => {
  const pts: string[] = [];
  const n = 12, step = 5, r = 260;
  let idx = 0;
  for (let k = 0; k < n; k++) {
    const a = (idx / n) * Math.PI * 2 - Math.PI / 2;
    pts.push(`${(C + Math.cos(a) * r).toFixed(1)} ${(C + Math.sin(a) * r).toFixed(1)}`);
    idx = (idx + step) % n;
  }
  return pts.join(' ');
})();
// ---- layer 3: seed of life ----
const seed = Array.from({ length: 6 }, (_, i) => {
  const a = (i / 6) * Math.PI * 2;
  return { cx: C + Math.cos(a) * 55, cy: C + Math.sin(a) * 55 };
});
---

<div class="home-atmos pointer-events-none fixed inset-0 z-0 overflow-hidden" aria-hidden="true">
  <Starfield class="absolute inset-0 h-full w-full" density={1} />

  <!-- emerging divine light -->
  <div class="home-light"></div>

  <!-- rotating five-layer mandala — each layer is its own SVG so it rotates as
       a single GPU-composited transform (no per-frame raster). -->
  <div class="home-mandala">
    <svg class="m-layer m-cw" style="animation-duration:150s" viewBox="0 0 1000 1000" fill="none" role="presentation">
      <g stroke="#E7C68B">
        {ticks.map((t) => (
          <line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} stroke-width={t.big ? 1.6 : 0.8} opacity={t.big ? 0.6 : 0.32} />
        ))}
        <circle cx={C} cy={C} r="440" stroke-width="0.6" opacity="0.28" />
      </g>
    </svg>
    <svg class="m-layer m-ccw" style="animation-duration:200s" viewBox="0 0 1000 1000" fill="none" role="presentation">
      <polygon points={star} stroke="#CC914E" stroke-width="1" opacity="0.4" />
      <circle cx={C} cy={C} r="260" stroke="#E7C68B" stroke-width="0.6" opacity="0.22" />
      <circle cx={C} cy={C} r="150" stroke="#E7C68B" stroke-width="0.7" opacity="0.5" />
      <circle cx={C} cy={C} r="205" stroke="#E7C68B" stroke-width="0.5" opacity="0.35" />
    </svg>
    <svg class="m-layer m-cw" style="animation-duration:170s" viewBox="0 0 1000 1000" fill="none" role="presentation">
      <g stroke="#F3E6C8" stroke-width="0.8" opacity="0.5">
        <circle cx={C} cy={C} r="55" />
        {seed.map((s) => <circle cx={s.cx} cy={s.cy} r="55" />)}
      </g>
    </svg>
  </div>
</div>

<style>
  .home-atmos { contain: strict; }

  /* central light that breathes */
  .home-light {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 78vmin;
    height: 78vmin;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(247, 240, 214, 0.2) 0%,
      rgba(231, 198, 139, 0.12) 28%,
      rgba(204, 145, 78, 0.05) 55%,
      transparent 74%
    );
    animation: atmos-breathe 11s var(--ease-soul, ease) infinite;
  }

  .home-mandala {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 126vmin;
    height: 126vmin;
    transform: translate(-50%, -50%);
    opacity: 0.6;
  }

  /* each layer is a full-size SVG that rotates as one composited transform */
  .m-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform-origin: center;
    will-change: transform;
  }
  .m-cw { animation: atmos-spin 1s linear infinite; }
  .m-ccw { animation: atmos-spin 1s linear infinite; animation-direction: reverse; }

  @keyframes atmos-spin { to { transform: rotate(360deg); } }
  @keyframes atmos-breathe {
    0%, 100% { opacity: 0.85; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-light { animation: none; }
    .m-cw, .m-ccw { animation: none; }
  }
</style>
