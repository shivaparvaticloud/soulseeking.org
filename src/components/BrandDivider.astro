---
// A coded brand band echoing the dot-painting: a field of concentric circles
// meeting a rectangular "maze" across a wavy oxblood river. Decorative, static,
// no images. Used as a section divider site-wide.
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 132 } = Astro.props;
const id = `riv-${Math.random().toString(36).slice(2, 7)}`;
---

<div
  class={`brand-divider relative w-full overflow-hidden ${className}`}
  style={`height:${height}px`}
  aria-hidden="true"
>
  <!-- left: concentric circles field -->
  <div class="bg-brand-circles absolute inset-y-0 left-0 right-1/2 opacity-40"></div>
  <!-- right: maze field -->
  <div class="bg-brand-maze absolute inset-y-0 left-1/2 right-0 opacity-40"></div>

  <!-- the wavy oxblood river down the middle -->
  <svg
    class="absolute inset-0 h-full w-full"
    viewBox="0 0 100 100"
    preserveAspectRatio="none"
    fill="none"
  >
    <defs>
      <linearGradient id={id} x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#692828" stop-opacity="0"></stop>
        <stop offset="50%" stop-color="#7a2f2f" stop-opacity="0.9"></stop>
        <stop offset="100%" stop-color="#692828" stop-opacity="0"></stop>
      </linearGradient>
    </defs>
    <path
      d="M50 0 C46 14 56 22 52 36 C48 50 58 60 53 74 C49 88 55 94 50 100"
      stroke={`url(#${id})`}
      stroke-width="3.2"
      vector-effect="non-scaling-stroke"
      style="stroke-width:4px"
    ></path>
    <path
      d="M50 0 C46 14 56 22 52 36 C48 50 58 60 53 74 C49 88 55 94 50 100"
      stroke="#E7C68B"
      stroke-width="0.6"
      vector-effect="non-scaling-stroke"
      opacity="0.5"
    ></path>
  </svg>

  <!-- top/bottom hairlines + a gentle darkening so it reads as a band -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-void/30 via-transparent to-void/30"></div>
  <div class="absolute inset-x-0 top-0 hairline"></div>
  <div class="absolute inset-x-0 bottom-0 hairline"></div>
</div>
