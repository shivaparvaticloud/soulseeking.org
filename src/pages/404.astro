---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
---

<Layout title="Lost the Path — Soul Seeking" description="This page could not be found." cosmos="comets" noindex={true}>
  <section class="relative flex min-h-[70vh] items-center justify-center overflow-hidden">
    <div class="pointer-events-none absolute inset-0 aurora opacity-60"></div>
    <div class="relative z-10 mx-auto max-w-xl px-6 text-center">
      <div class="flex justify-center">
        <Logo size={96} />
      </div>
      <p class="mt-phi-1 accent text-gold">404</p>
      <h1 class="mt-2 display-xl">The Path Forks Here</h1>
      <p class="mx-auto mt-phi-1 max-w-md font-serif text-lg leading-loose text-mist/70">
        What you sought is not at this turning. But the seeker who keeps looking always finds
        the way &mdash; for what you seek, you will attract.
      </p>
      <div class="mt-phi-2 flex flex-wrap justify-center gap-4">
        <a href="/" class="btn-soul">Return Home</a>
        <a href="/knowledge" class="btn-soul-dark">Knowledge Hub</a>
      </div>
    </div>
  </section>
</Layout>
