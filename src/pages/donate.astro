---
import Layout from '../layouts/Layout.astro';
import Phyllotaxis from '../components/Phyllotaxis.astro';
import ArtPlate from '../components/ArtPlate.astro';

const steps = [
  'Help three people, freely and without expectation.',
  'Ask each of them to help three others in turn.',
  'Tell no one to thank you — let the giving travel onward.',
];
---

<Layout
  title="Give Onward — Soul Seeking"
  description="There is no fee and no donation button. Instead, help three people and ask them to help three others."
  fxPage="donate"
>
  <header class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 aurora opacity-60"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-6 py-phi-4 text-center">
      <div class="flex justify-center">
        <Phyllotaxis size={150} points={520} tone="gold" class="opacity-85" />
      </div>
      <h1 data-reveal-lines class="mt-phi-1 display-xl">Give Onward</h1>
      <p class="mx-auto mt-phi-1 max-w-xl font-serif text-lg leading-loose text-mist/70">
        This work is offered freely. There is nothing to buy and no button to press.
      </p>
    </div>
  </header>

  <section class="border-t border-white/10">
    <div class="mx-auto max-w-reading px-6 py-phi-4 text-center">
      <blockquote class="pull text-3xl leading-relaxed text-mist">
        &ldquo;Instead of thanking us, help three people &mdash; and tell them to help three
        others.&rdquo;
      </blockquote>

      <ol class="mx-auto mt-phi-3 max-w-md space-y-phi-1 text-left">
        {
          steps.map((s, i) => (
            <li class="reveal flex items-start gap-4">
              <span class="mt-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/10 text-gold">
                {i + 1}
              </span>
              <span class="font-serif text-lg leading-loose text-mist/70">{s}</span>
            </li>
          ))
        }
      </ol>

      <p class="mx-auto mt-phi-3 max-w-lg font-serif text-lg leading-loose text-mist/65">
        This is the only donation we ask: a quiet chain of kindness with no end and no ledger.
        What you seek, you will attract; what you give, you set free. The path continues
        onward, independently.
      </p>

      <div class="mx-auto mt-phi-2 max-w-xs">
        <div class="art-frame">
          <ArtPlate variant="tablet" />
        </div>
      </div>

      <div class="mt-phi-2">
        <a href="/knowledge" class="btn-soul">Return to the Search</a>
      </div>
    </div>
  </section>
</Layout>
