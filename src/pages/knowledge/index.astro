---
import Layout from '../../layouts/Layout.astro';
import { getArticles, getCategories } from '../../lib/content';

const articles = getArticles();
const categories = getCategories();
---

<Layout
  title="Knowledge Hub — Soul Seeking"
  description="Reflections and resources on life, Spirit and the soul — read slowly, one writing at a time."
  hasSearch={true}
>
  <header class="border-b border-white/10">
    <div class="mx-auto max-w-4xl px-6 py-phi-4 text-center">
      <p class="kicker kicker--center">01 — Reflections &amp; Resources</p>
      <h1 class="mt-4 display-xl text-mist">Knowledge Hub</h1>
      <p class="mx-auto mt-phi-1 max-w-xl font-serif text-lg leading-loose text-mist/70">
        Wisdom on life, Spirit and the soul. Read slowly; let a single line work on you
        for a day.
      </p>
      <div class="rule-gold mx-auto mt-phi-2 w-40"></div>
    </div>
  </header>

  <div class="mx-auto max-w-6xl px-6 py-phi-3">
    {
      categories.length > 1 && (
        <nav class="mb-phi-2 flex flex-wrap justify-center gap-x-6 gap-y-2" aria-label="Categories">
          {categories.map((c) => (
            <a
              href={`#${c.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
              class="font-sans text-[0.7rem] uppercase tracking-extreme text-mist/70 transition-phi hover:text-gold"
            >
              {c.name} <span class="text-mist/40">({c.count})</span>
            </a>
          ))}
        </nav>
      )
    }

    {
      categories.map((cat) => {
        const items = articles.filter((a) => a.category === cat.name);
        return (
          <section
            id={cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}
            class="scroll-mt-28 border-t border-white/10 py-phi-3 first:border-t-0"
          >
            <div class="mb-phi-2 flex items-baseline gap-4">
              <h2 class="display-lg text-mist">{cat.name}</h2>
              <div class="hairline flex-1" />
            </div>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {items.map((a) => (
                <a
                  href={`/knowledge/${a.slug}`}
                  class="card-soul reveal group flex flex-col p-phi-2"
                >
                  <span class="font-sans text-[0.6rem] uppercase tracking-[0.3em] text-gold/70">
                    {a.readingMinutes} min
                  </span>
                  <h3 class="mt-3 display-lg text-2xl text-mist">{a.title}</h3>
                  <p class="mt-3 flex-1 font-serif leading-loose text-mist/65">
                    {a.description}
                  </p>
                  <span class="mt-6 inline-flex items-center gap-2 font-sans text-[0.66rem] uppercase tracking-[0.22em] text-mist transition-phi group-hover:text-gold">
                    Read{' '}
                    <span aria-hidden="true" class="transition-phi group-hover:translate-x-1">
                      &rarr;
                    </span>
                  </span>
                </a>
              ))}
            </div>
          </section>
        );
      })
    }

    {
      articles.length === 0 && (
        <p class="py-phi-3 text-center font-serif text-mist/70">
          No writings yet. Drop a <code>.txt</code> file into <code>content/knowledge/</code>{' '}
          and it will appear here, fully formatted.
        </p>
      )
    }
  </div>
</Layout>
