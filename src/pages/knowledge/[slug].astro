---
import Layout from '../../layouts/Layout.astro';
import Blocks from '../../components/Blocks.astro';
import Glossary from '../../components/Glossary.astro';
import ThreeModes from '../../components/ThreeModes.astro';
import ArtPlate from '../../components/ArtPlate.astro';
import { getArticles } from '../../lib/content';

const ARTS = ['yantra','mandala','kolam','jali','sahasrara','origins','songline','tablet','stardust','weave'];

export function getStaticPaths() {
  return getArticles().map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article } = Astro.props;
const all = getArticles();
const idx = all.findIndex((a) => a.slug === article.slug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;
const artVariant = ARTS[((idx >= 0 ? idx : 0) % ARTS.length + ARTS.length) % ARTS.length];

const toc = article.blocks.filter(
  (b): b is Extract<typeof b, { kind: 'heading' }> => b.kind === 'heading' && b.level <= 3
);

// The three guṇas weave behind their own article.
const showThreeModes = /three-modes|gunas|guna/i.test(article.slug);

const site = Astro.site ?? new URL('https://soulseeking.org');
const url = new URL(Astro.url.pathname, site).toString();
const jsonld = [
  {
    '@type': 'Article',
    headline: article.title,
    description: article.description,
    inLanguage: 'en',
    articleSection: article.category,
    wordCount: article.wordCount,
    timeRequired: `PT${article.readingMinutes}M`,
    author: { '@type': 'Organization', name: article.author || 'Soul Seeking' },
    publisher: { '@id': new URL('/#org', site).toString() },
    isAccessibleForFree: true,
    mainEntityOfPage: url,
    url,
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.toString() },
      { '@type': 'ListItem', position: 2, name: 'Knowledge Hub', item: new URL('/knowledge/', site).toString() },
      { '@type': 'ListItem', position: 3, name: article.title, item: url },
    ],
  },
];
---

<Layout title={`${article.title} — Soul Seeking`} description={article.description} hasSearch={true} fxPage="knowledge" cosmos="eclipse" ogType="article" jsonld={jsonld}>
  <article data-pagefind-body>
    <!-- Title page -->
    <header class="relative">
      <div class="mx-auto max-w-reading px-6 py-phi-4 text-center">
        <p class="kicker" data-pagefind-meta="category">{article.category}</p>
        <h1 data-reveal-lines class="mt-5 display-xl text-balance text-mist">
          {article.title}
        </h1>
        <figure class="card-soul mx-auto mt-phi-2 max-w-[16rem] overflow-hidden">
          <div class="aspect-[3/4] w-full overflow-hidden rounded">
            <ArtPlate variant={artVariant} />
          </div>
        </figure>
        {
          article.quote && (
            <blockquote class="pull mx-auto mt-phi-2 max-w-xl text-balance text-3xl leading-relaxed text-mist">
              &ldquo;{article.quote}&rdquo;
            </blockquote>
          )
        }
        {
          showThreeModes && (
            <div class="mx-auto mt-phi-2 w-full max-w-lg">
              <ThreeModes width={600} height={130} class="w-full" />
            </div>
          )
        }
        <p class="mt-phi-2 font-sans text-[0.62rem] uppercase tracking-[0.22em] text-mist/50">
          {article.author} &middot; {article.readingMinutes} min read
        </p>
      </div>
      <div class="hairline mx-auto w-40"></div>
    </header>

    <div class="mx-auto max-w-reading px-6 py-phi-3">
      {
        toc.length >= 3 && (
          <nav class="mb-phi-2 rounded-sm border border-white/10 bg-abyss p-phi-1" aria-label="On this page">
            <p class="kicker mb-2">On This Page</p>
            <ol class="space-y-1.5">
              {toc.map((h) => (
                <li class={h.level === 3 ? 'pl-4' : ''}>
                  <a href={`#${h.id}`} class="text-sm text-mist/70 hover:text-gold">
                    {h.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }

      <div class="prose prose-soul max-w-none">
        <Blocks blocks={article.blocks} tone="dark" />
      </div>

      {
        article.glossary.length > 0 && (
          <div class="mt-phi-3">
            <Glossary items={article.glossary} tone="dark" />
          </div>
        )
      }
    </div>

    <!-- prev / next -->
    <nav
      class="mx-auto mb-phi-3 grid max-w-reading gap-4 px-6 sm:grid-cols-2"
      aria-label="More writings"
    >
      {
        prev ? (
          <a href={`/knowledge/${prev.slug}`} class="card-soul group p-phi-2">
            <span class="accent text-gold">&larr; Previous</span>
            <p class="mt-1 text-mist group-hover:text-gold">{prev.title}</p>
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a href={`/knowledge/${next.slug}`} class="card-soul group p-phi-2 text-right">
            <span class="accent text-gold">Next &rarr;</span>
            <p class="mt-1 text-mist group-hover:text-gold">{next.title}</p>
          </a>
        ) : (
          <span />
        )
      }
    </nav>

    <div class="pb-phi-3 text-center">
      <a href="/knowledge" class="btn-link">All Writings</a>
    </div>
  </article>
</Layout>
