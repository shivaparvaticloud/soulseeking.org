---
import Layout from '../../layouts/Layout.astro';
import Blocks from '../../components/Blocks.astro';
import Glossary from '../../components/Glossary.astro';
import SunburstRays from '../../components/SunburstRays.astro';
import MeditationFigures from '../../components/MeditationFigures.astro';
import ThreeModes from '../../components/ThreeModes.astro';
import { getArticles } from '../../lib/content';

export function getStaticPaths() {
  return getArticles().map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article } = Astro.props;
const all = getArticles();
const idx = all.findIndex((a) => a.slug === article.slug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;

const toc = article.blocks.filter(
  (b): b is Extract<typeof b, { kind: 'heading' }> => b.kind === 'heading' && b.level <= 3
);

// The three guṇas weave behind their own article.
const showThreeModes = /three-modes|gunas|guna/i.test(article.slug);
---

<Layout title={`${article.title} — Soul Seeking`} description={article.description} hasSearch={true}>
  <article data-pagefind-body>
    <!-- Title page -->
    <header class="relative overflow-hidden bg-cosmos text-cream">
      <MeditationFigures class="absolute inset-0 h-full w-full" tone="gold" opacity={0.28} />
      <div class="relative z-10 mx-auto max-w-reading px-6 py-phi-4 text-center">
        <p class="accent text-gold" data-pagefind-meta="category">{article.category}</p>
        <h1 class="mt-3 text-balance text-4xl leading-tight tracking-wider sm:text-5xl">
          {article.title}
        </h1>
        {
          article.quote && (
            <blockquote class="mx-auto mt-phi-2 max-w-xl text-balance text-lg italic leading-loose text-cream/80">
              &ldquo;{article.quote}&rdquo;
            </blockquote>
          )
        }
        {
          showThreeModes && (
            <div class="mx-auto mt-phi-2 w-full max-w-lg">
              <ThreeModes width={600} height={130} class="w-full" />
            </div>
          )
        }
        <p class="mt-phi-2 text-[0.65rem] uppercase tracking-ultra text-cream/50">
          {article.author} &middot; {article.readingMinutes} min read
        </p>
      </div>
      <div class="h-10">
        <SunburstRays width={1200} height={110} rays={72} tone="gold" />
      </div>
    </header>

    <div class="mx-auto max-w-reading px-6 py-phi-3">
      {
        toc.length >= 3 && (
          <nav class="mb-phi-2 rounded-sm border border-gold/30 bg-parchment/40 p-phi-1" aria-label="On this page">
            <p class="accent mb-2 text-ochre">On This Page</p>
            <ol class="space-y-1.5">
              {toc.map((h) => (
                <li class={h.level === 3 ? 'pl-4' : ''}>
                  <a href={`#${h.id}`} class="text-sm text-earth/80 hover:text-oxblood">
                    {h.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }

      <div class="prose-soul">
        <Blocks blocks={article.blocks} tone="light" />
      </div>

      {
        article.glossary.length > 0 && (
          <div class="mt-phi-3">
            <Glossary items={article.glossary} tone="light" />
          </div>
        )
      }
    </div>

    <!-- prev / next -->
    <nav
      class="mx-auto mb-phi-3 grid max-w-reading gap-4 px-6 sm:grid-cols-2"
      aria-label="More writings"
    >
      {
        prev ? (
          <a href={`/knowledge/${prev.slug}`} class="group rounded-sm border border-gold/30 p-phi-1 transition-phi hover:border-ochre">
            <span class="accent text-ochre">&larr; Previous</span>
            <p class="mt-1 text-earth group-hover:text-oxblood">{prev.title}</p>
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a href={`/knowledge/${next.slug}`} class="group rounded-sm border border-gold/30 p-phi-1 text-right transition-phi hover:border-ochre">
            <span class="accent text-ochre">Next &rarr;</span>
            <p class="mt-1 text-earth group-hover:text-oxblood">{next.title}</p>
          </a>
        ) : (
          <span />
        )
      }
    </nav>

    <div class="pb-phi-3 text-center">
      <a href="/knowledge" class="btn-soul-dark">All Writings</a>
    </div>
  </article>
</Layout>
