---
import Layout from '../../layouts/Layout.astro';
import Blocks from '../../components/Blocks.astro';
import Glossary from '../../components/Glossary.astro';
import Quiz from '../../components/Quiz.astro';
import ArtPlate from '../../components/ArtPlate.astro';
import ProgressFooter from '../../components/ProgressFooter.astro';
import CourseChapterNav from '../../components/CourseChapterNav.astro';
import { getCourses } from '../../lib/content';

export function getStaticPaths() {
  return getCourses().map((c) => ({ params: { slug: c.slug }, props: { course: c } }));
}

const { course } = Astro.props;
const levelName = ['', 'Foundation', 'Seeker', 'Adept', 'Deepening', 'Mastery'];
const markerModules = course.modules.map((m) => ({ number: m.number, title: m.title }));
const romans = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X', 'XI', 'XII'];

const site = Astro.site ?? new URL('https://soulseeking.org');
const url = new URL(Astro.url.pathname, site).toString();
const jsonld = [
  {
    '@type': 'Course',
    name: course.title,
    description: course.description,
    inLanguage: 'en',
    url,
    provider: { '@type': 'Organization', name: 'Soul Seeking', '@id': new URL('/#org', site).toString() },
    isAccessibleForFree: true,
    timeRequired: `PT${course.readingMinutes}M`,
    numberOfCredits: course.modules.length,
    hasCourseInstance: {
      '@type': 'CourseInstance',
      courseMode: 'online',
      courseWorkload: `PT${course.readingMinutes}M`,
    },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.toString() },
      { '@type': 'ListItem', position: 2, name: 'Courses', item: new URL('/courses/', site).toString() },
      { '@type': 'ListItem', position: 3, name: course.title, item: url },
    ],
  },
];
---

<Layout title={`${course.title} — Soul Seeking`} description={course.description} hasSearch={true} fxPage="courses" cosmos="pulsar" ogType="article" jsonld={jsonld}>
  <CourseChapterNav modules={markerModules} hasBrief={course.brief.length > 0} />
  <article data-pagefind-body>
    <!-- Title page -->
    <header class="relative flex min-h-[80vh] items-center">
      <div class="mx-auto max-w-3xl px-6 py-phi-4 text-center">
        <p class="kicker">
          {levelName[course.level] || `Level ${course.level}`} &middot; A Course in {course.modules.length} Modules
        </p>
        <h1 data-reveal-lines class="mt-5 display-xl text-balance text-mist">
          {course.title}
        </h1>
        {course.tagline && <p class="mt-phi-1 font-serif text-xl text-mist/70">{course.tagline}</p>}
        <figure class="card-soul mx-auto mt-phi-2 max-w-[16rem] overflow-hidden">
          <div class="aspect-[3/4] w-full overflow-hidden rounded">
            <ArtPlate variant="sahasrara" />
          </div>
        </figure>
        <p class="mt-phi-2 font-sans text-[0.62rem] uppercase tracking-[0.22em] text-mist/50">
          {course.readingMinutes} min &middot; Read at your own pace
        </p>
        <div class="mt-phi-2">
          <a href="#brief" class="btn-soul">Begin the Course</a>
        </div>
      </div>
      <div class="absolute inset-x-0 bottom-0 hairline mx-auto w-40"></div>
    </header>

    <!-- Brief & outcomes -->
    <section id="brief" class="scroll-mt-24 border-t border-white/10">
      <div class="mx-auto max-w-reading px-6 py-phi-4">
        {
          course.brief.length > 0 && (
            <div class="prose prose-soul max-w-none">
              <Blocks blocks={course.brief} tone="dark" />
            </div>
          )
        }
        {
          course.outcomes.length > 0 && (
            <div class="mt-phi-2 rounded-sm border border-white/10 bg-abyss p-phi-2">
              <p class="kicker">What You Will Uncover</p>
              <ul class="mt-phi-1 space-y-2 pl-6 marker:text-gold" style="list-style-type: disc">
                {course.outcomes.map((o) => (
                  <li class="text-mist/70" set:html={o} />
                ))}
              </ul>
            </div>
          )
        }
      </div>
    </section>

    <!-- Modules as chapters -->
    {
      course.modules.map((m) => (
        <section
          id={`module-${m.number}`}
          class="scroll-mt-24 border-t border-white/10"
          data-module-marker
          data-module-number={m.number}
          data-module-title={m.title}
        >
          <div class="mx-auto max-w-reading px-6 py-phi-4">
            <div class="text-center">
              <p class="kicker">Module {romans[m.number - 1] || m.number}</p>
              <h2 class="mt-2 text-balance display-lg text-mist">
                {m.title}
              </h2>
              <div class="rule-gold mx-auto mt-5 w-40" />
            </div>

            {m.intro.length > 0 && (
              <div class="prose prose-soul max-w-none mt-phi-2">
                <Blocks blocks={m.intro} tone="dark" />
              </div>
            )}

            {m.body.length > 0 && (
              <div class="prose prose-soul max-w-none mt-phi-1">
                <Blocks blocks={m.body} tone="dark" />
              </div>
            )}

            {m.glossary.length > 0 && (
              <div class="mt-phi-2">
                <Glossary items={m.glossary} tone="dark" />
              </div>
            )}

            {m.summary.length > 0 && (
              <div class="mt-phi-2 rounded-sm border-l-2 border-gold/60 bg-abyss py-phi-1 pl-phi-1 pr-4">
                <p class="kicker">In Essence</p>
                <div class="mt-2">
                  <Blocks blocks={m.summary} tone="dark" />
                </div>
              </div>
            )}

            {m.quiz.length > 0 && (
              <Quiz
                questions={m.quiz}
                kicker={`Module ${romans[m.number - 1] || m.number} Quiz`}
                title="Check Your Understanding"
              />
            )}
          </div>
        </section>
      ))
    }

    <!-- Course summary -->
    {
      course.summary.length > 0 && (
        <section class="border-t border-white/10">
          <div class="mx-auto max-w-reading px-6 py-phi-4">
            <p class="kicker text-center">In Closing</p>
            <h2 class="mt-2 text-center display-lg text-mist">Course Summary</h2>
            <div class="prose prose-soul max-w-none mt-phi-2">
              <Blocks blocks={course.summary} tone="dark" />
            </div>
          </div>
        </section>
      )
    }

    <!-- Final course quiz -->
    {
      course.finalQuiz.length > 0 && (
        <section class="border-t border-white/10">
          <div class="mx-auto max-w-reading px-6 py-phi-4">
            <Quiz questions={course.finalQuiz} kicker="Course Quiz" title="The Whole Path" />
          </div>
        </section>
      )
    }

    <div class="pb-phi-4 text-center">
      <a href="/courses" class="btn-link">All Courses</a>
    </div>
  </article>

  <ProgressFooter modules={markerModules} />
</Layout>
