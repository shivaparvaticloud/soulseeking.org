---
import Layout from '../layouts/Layout.astro';
import SunburstRays from '../components/SunburstRays.astro';
import MeditationFigures from '../components/MeditationFigures.astro';

const suggestions = ['soul', 'self', 'kosa', 'gunas', 'cosmos', 'seeking'];
---

<Layout
  title="Search — Soul Seeking"
  description="Search every writing, course and page of Soul Seeking by keyword."
  hasSearch={true}
>
  <header class="relative overflow-hidden bg-cosmos text-cream">
    <MeditationFigures class="absolute inset-0 h-full w-full" tone="gold" opacity={0.3} />
    <div class="relative z-10 mx-auto max-w-3xl px-6 py-phi-3 text-center">
      <p class="accent text-gold">Find Your Thread</p>
      <h1 class="mt-2 text-4xl tracking-ultra sm:text-5xl">Search</h1>
      <p class="mx-auto mt-phi-1 max-w-xl text-cream/80">
        Type any word and search across every writing, course and page. What you seek, you
        will attract.
      </p>
    </div>
    <div class="h-8">
      <SunburstRays width={1200} height={90} rays={60} tone="gold" />
    </div>
  </header>

  <div class="mx-auto max-w-3xl px-6 py-phi-3">
    <form id="searchForm" role="search" autocomplete="off" novalidate>
      <label for="searchInput" class="sr-only">Search the site</label>
      <div class="relative">
        <svg
          class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-ochre"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="16.5" y1="16.5" x2="21" y2="21" stroke-linecap="round"></line>
        </svg>
        <input
          id="searchInput"
          type="search"
          name="q"
          placeholder="Search for a word — soul, kosa, gunas…"
          class="w-full rounded-sm border-2 border-ochre/50 bg-cream py-4 pl-12 pr-4 text-lg text-earth shadow-sm transition-phi placeholder:text-earth/40 focus:border-ochre focus:outline-none focus:ring-2 focus:ring-ochre/30"
          aria-describedby="searchStatus"
        />
      </div>
    </form>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <span class="accent text-[0.6rem] text-earth/50">Try</span>
      {
        suggestions.map((s) => (
          <button
            type="button"
            class="search-chip rounded-full border border-gold/50 px-3 py-1 text-xs tracking-wide text-oxblood transition-phi hover:border-ochre hover:bg-parchment/60"
            data-term={s}
          >
            {s}
          </button>
        ))
      }
    </div>

    <p id="searchStatus" class="mt-phi-2 accent text-ochre" aria-live="polite">
      Type a word to search every page of the site.
    </p>
    <ul id="searchResults" class="ss-results mt-phi-1 space-y-4"></ul>

    <noscript>
      <p class="mt-phi-1 text-center text-earth/70">Search requires JavaScript to be enabled.</p>
    </noscript>
  </div>
</Layout>

<style is:global>
  .ss-results mark {
    background-color: #e7c68b;
    color: #692828;
    padding: 0 0.15em;
    border-radius: 2px;
  }
</style>

<script is:inline>
  (() => {
    const form = document.getElementById('searchForm');
    const input = document.getElementById('searchInput');
    const status = document.getElementById('searchStatus');
    const results = document.getElementById('searchResults');
    if (!form || !input || !status || !results) return;

    let docs = [];
    let ready = false;

    const esc = (s) =>
      String(s).replace(
        /[&<>"']/g,
        (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]
      );

    const fold = (s) => s.normalize('NFKD').replace(/[\u0300-\u036f]/g, '');

    const terms = (q) =>
      fold(q.toLowerCase())
        .split(/[^a-z0-9]+/)
        .filter((t) => t.length >= 2);

    const countHits = (hay, t) => {
      let n = 0;
      let i = hay.indexOf(t);
      while (i !== -1) {
        n++;
        i = hay.indexOf(t, i + t.length);
      }
      return n;
    };

    const scoreDoc = (doc, ts) => {
      const title = fold(doc.title.toLowerCase());
      const cat = fold((doc.category + ' ' + doc.type).toLowerCase());
      const ex = fold(doc.excerpt.toLowerCase());
      const body = doc.body.toLowerCase();
      let score = 0;
      let matchedAll = true;
      for (const t of ts) {
        let s = 0;
        if (title.includes(t)) s += 12;
        if (cat.includes(t)) s += 5;
        if (ex.includes(t)) s += 4;
        s += Math.min(countHits(body, t), 6);
        if (s === 0) matchedAll = false;
        score += s;
      }
      return matchedAll ? score : 0;
    };

    const highlight = (text, ts) => {
      if (!ts.length) return esc(text);
      const pattern = ts.map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|');
      const re = new RegExp('(' + pattern + ')', 'gi');
      let out = '';
      let last = 0;
      let m;
      while ((m = re.exec(text)) !== null) {
        out += esc(text.slice(last, m.index)) + '<mark>' + esc(m[0]) + '</mark>';
        last = m.index + m[0].length;
        if (m.index === re.lastIndex) re.lastIndex++;
      }
      return out + esc(text.slice(last));
    };

    const snippet = (doc, ts) => {
      const text = doc.body || doc.excerpt || '';
      const lower = text.toLowerCase();
      let pos = -1;
      for (const t of ts) {
        const i = lower.indexOf(t);
        if (i >= 0 && (pos < 0 || i < pos)) pos = i;
      }
      if (pos < 0) pos = 0;
      const start = Math.max(0, pos - 60);
      let slice = text.slice(start, start + 200);
      if (start > 0) slice = '\u2026' + slice;
      if (start + 200 < text.length) slice = slice + '\u2026';
      return highlight(slice, ts);
    };

    const render = (q) => {
      const ts = terms(q);
      if (!ready) {
        status.textContent = 'Loading the index\u2026';
        return;
      }
      if (!ts.length) {
        results.innerHTML = '';
        status.textContent = 'Type a word to search every page of the site.';
        return;
      }
      const scored = docs
        .map((d) => ({ d, s: scoreDoc(d, ts) }))
        .filter((x) => x.s > 0)
        .sort((a, b) => b.s - a.s)
        .slice(0, 40);

      if (!scored.length) {
        results.innerHTML = '';
        status.textContent =
          'No results for \u201c' + q + '\u201d. Try another word \u2014 perhaps \u201csoul\u201d, \u201ckosa\u201d or \u201cgunas\u201d.';
        return;
      }
      status.textContent =
        scored.length + ' result' + (scored.length > 1 ? 's' : '') + ' for \u201c' + q + '\u201d.';
      results.innerHTML = scored
        .map(({ d }) => {
          const label =
            esc(d.type) + (d.category && d.category !== d.type ? ' \u00b7 ' + esc(d.category) : '');
          return (
            '<li><a href="' +
            esc(d.url) +
            '" class="group block rounded-sm border border-gold/40 bg-parchment/30 p-phi-1 transition-phi hover:border-ochre hover:bg-parchment/60">' +
            '<span class="block accent text-[0.6rem] text-ochre">' +
            label +
            '</span>' +
            '<span class="mt-1 block text-xl tracking-wide text-oxblood">' +
            esc(d.title) +
            '</span>' +
            '<span class="mt-2 block leading-relaxed text-earth/80">' +
            snippet(d, ts) +
            '</span></a></li>'
          );
        })
        .join('');
    };

    const syncUrl = (q) => {
      const u = new URL(location.href);
      if (q) u.searchParams.set('q', q);
      else u.searchParams.delete('q');
      history.replaceState(null, '', u);
    };

    let timer;
    input.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => {
        const q = input.value.trim();
        render(q);
        syncUrl(q);
      }, 120);
    });
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      render(q);
      syncUrl(q);
    });

    document.querySelectorAll('.search-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const term = chip.getAttribute('data-term') || '';
        input.value = term;
        render(term);
        syncUrl(term);
        input.focus();
      });
    });

    const initial = (new URLSearchParams(location.search).get('q') || '').trim();
    if (initial) input.value = initial;

    fetch('/search-index.json')
      .then((r) => r.json())
      .then((data) => {
        docs = Array.isArray(data) ? data : [];
        ready = true;
        render(input.value.trim());
      })
      .catch(() => {
        status.textContent = 'The search index could not be loaded. Please try again.';
      });

    input.focus();
  })();
</script>
