---
import Layout from '../layouts/Layout.astro';
import Nadis from '../components/Nadis.astro';
import ArtPlate from '../components/ArtPlate.astro';

const personality = [
  {
    name: 'Confronting',
    body: 'Truth does not always console. We will not flatter you or sell easy certainty. The path asks honest looking, even when what is seen unsettles.',
  },
  {
    name: 'Authentic',
    body: 'No imitation, no spectacle, no hidden motive. What is offered here is drawn faithfully from the ancient sources and tested against direct experience.',
  },
  {
    name: 'Encouraging',
    body: 'For the earnest seeker there is always success. We trust you to find what is real, and we walk beside you — never above you.',
  },
];

const values = [
  { name: 'Authenticity', body: 'Faithful to the source; honest in the telling.' },
  { name: 'Simplicity', body: 'Subtracting rather than accumulating; clear over clever.' },
  { name: 'Quality', body: 'Depth over reach; the few true words over the many.' },
];
---

<Layout title="About — Soul Seeking" description="Who we are, what we value, and why this quiet quest exists." fxPage="about">
  <header class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 aurora opacity-60"></div>
    <div class="relative z-10 mx-auto flex max-w-4xl flex-col items-center px-6 py-phi-4 text-center">
      <h1 data-reveal-lines class="display-xl">About Soul Seeking</h1>
      <p class="mt-phi-1 max-w-xl font-serif text-lg leading-loose text-mist/70">
        A quiet place for the oldest questions — uncovering life, truth and Spirit, step by step.
      </p>
    </div>
  </header>

  <section class="border-t border-white/10">
    <div class="mx-auto grid max-w-5xl items-center gap-phi-2 px-6 py-phi-4 md:grid-cols-[1fr_auto]">
      <div>
        <p class="pull text-3xl leading-relaxed text-mist">
          Soul Seeking is an outreach for inward travellers: a self-contained library of
          wisdom, courses and reflections on the Self, the cosmos and the way to live. It asks
          nothing of you but sincerity. There is no membership, no fee, and no contact to make —
          only a path that continues onward, independently.
        </p>
        <p class="mt-phi-2 font-serif text-lg leading-loose text-mist/70">
          The teachings gathered here are old; the manner of gathering them is plain. We hold
          that for the earnest seeker there will always be success, for what you seek, you will
          attract. Our task is simply to keep the lamp lit and the path clear.
        </p>
      </div>
      <figure class="card-soul overflow-hidden md:w-64">
        <div class="aspect-[3/4] w-full overflow-hidden rounded">
          <ArtPlate variant="mandala" />
        </div>
        <figcaption class="mt-4 font-sans text-[0.66rem] uppercase tracking-[0.22em] text-mist/70">
          Mandala — drawn in code
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="border-t border-white/10">
    <div class="mx-auto max-w-5xl px-6 py-phi-4">
      <p class="kicker kicker--center">01 — Our Personality</p>
      <h2 class="mt-2 text-center display-lg">How We Walk</h2>
      <div class="mt-phi-2 grid gap-6 md:grid-cols-3">
        {
          personality.map((p) => (
            <div class="card-soul reveal p-phi-2">
              <h3 class="text-2xl">{p.name}</h3>
              <p class="mt-3 font-serif text-lg leading-loose text-mist/65">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-white/10">
    <div class="mx-auto grid max-w-5xl items-center gap-phi-2 px-6 py-phi-4 md:grid-cols-[1fr_auto]">
      <div>
        <p class="kicker">02 — Our Values</p>
        <h2 class="mt-2 display-lg">The Threefold Measure</h2>
        <dl class="mt-phi-2 space-y-phi-1">
          {
            values.map((v) => (
              <div class="border-l border-white/10 pl-5">
                <dt class="text-2xl text-gold">{v.name}</dt>
                <dd class="mt-1 font-serif text-lg leading-loose text-mist/65">{v.body}</dd>
              </div>
            ))
          }
        </dl>
      </div>
      <div class="hidden justify-center md:flex">
        <Nadis size={260} tone="gold" />
      </div>
    </div>
  </section>

  <section class="border-t border-white/10">
    <div class="mx-auto max-w-reading px-6 py-phi-4 text-center">
      <blockquote class="pull text-3xl leading-relaxed text-mist">
        &ldquo;Who looks outside, dreams; who looks inside, awakes.&rdquo;
      </blockquote>
      <p class="mt-phi-1 accent text-gold">C.G. Jung</p>
      <div class="mt-phi-2">
        <a href="/knowledge" class="btn-soul">Begin Reading</a>
      </div>
    </div>
  </section>
</Layout>
