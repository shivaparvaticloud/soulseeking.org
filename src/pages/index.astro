---
import Layout from '../layouts/Layout.astro';
import HomeAtmosphere from '../components/HomeAtmosphere.astro';
import Phyllotaxis from '../components/Phyllotaxis.astro';
import KosaScene from '../components/KosaScene.astro';
import ArtPlate from '../components/ArtPlate.astro';
import { getCourses, getArticles } from '../lib/content';

const courses = getCourses();
const articles = getArticles();
---

<Layout
  title="Soul Seeking — Higher Answers for Deeper Questions"
  description="Timeless answers to the questions that matter most — on meaning, the mind, and the Self within. A calm, modern path drawn from the world’s oldest wisdom."
  fxPage="home"
>
  <HomeAtmosphere />

  <!-- ░░ HERO — the cosmos ░░ -->
  <section class="relative flex min-h-[92vh] items-center justify-center overflow-hidden">
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-b from-transparent to-void/80"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
      <p class="fade-in kicker kicker--center justify-center">A quiet quest within</p>
      <h1 class="fade-in-1 mt-7 display-xl text-mist">
        Soul Seeking
      </h1>
      <p class="fade-in-2 mx-auto mt-7 max-w-xl font-serif text-lg leading-relaxed text-mist/75 sm:text-xl">
        Timeless answers to the questions that matter most — on meaning, the mind,
        and the Self within. A calm, modern path drawn from the world’s oldest wisdom.
      </p>
      <div class="fade-in-3 mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/knowledge" class="btn-soul">Begin the Search</a>
        <a href="/courses" class="btn-soul-dark">Walk a Course</a>
      </div>
    </div>

    <div class="fade-in-4 absolute bottom-7 left-1/2 z-10 -translate-x-1/2">
      <span class="flex flex-col items-center gap-2 font-sans text-[0.55rem] uppercase tracking-[0.3em] text-mist/40">
        Scroll to begin
        <svg width="14" height="22" viewBox="0 0 14 22" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <rect x="1" y="1" width="12" height="20" rx="6"></rect>
          <line x1="7" y1="6" x2="7" y2="10" stroke-linecap="round"></line>
        </svg>
      </span>
    </div>
  </section>

  <!-- ░░ THE INVITATION ░░ -->
  <section class="relative overflow-hidden border-t border-white/10">
    <div class="mx-auto max-w-5xl px-6 py-phi-4">
      <p class="reveal kicker">01 — The Invitation</p>
      <blockquote data-reveal-lines class="mt-8 pull text-3xl leading-tight text-mist sm:text-4xl md:text-5xl">
        “The desire to know the Soul is the desire that will end all others.”
      </blockquote>

      <div class="reveal-delay mt-phi-2 grid gap-phi-1 text-mist/70 md:grid-cols-2">
        <p class="font-serif text-lg leading-loose">
          Walk the ancient path to life’s highest truths and deepest secrets. Here you
          will find wisdom, courses, reflections and resources that enlighten us on life,
          Spirit and the soul.
        </p>
        <p class="font-serif text-lg leading-loose">
          Endless questions from an inquisitive, earnest soul. It has been said that for
          the earnest seeker there will always be success &mdash; for what you seek, you
          will attract. Let us find a quiet place and begin your inward search.
        </p>
      </div>

      <div class="reveal mt-phi-2 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-white/10 pt-7 font-serif italic text-mist/55">
        <span>What is the purpose of life?</span>
        <span class="text-gold/40">·</span>
        <span>Who am I?</span>
        <span class="text-gold/40">·</span>
        <span>What is this entire cosmos and creation?</span>
        <span class="text-gold/40">·</span>
        <span>How should I truly live?</span>
      </div>
    </div>
  </section>

  <!-- ░░ THE ETERNAL SOUL — Gītā 2.23 ░░ -->
  <section class="relative overflow-hidden border-t border-white/10">
    <div class="relative z-10 mx-auto flex max-w-4xl flex-col items-center px-6 py-phi-4 text-center">
      <Phyllotaxis size={120} points={420} tone="gold" class="reveal opacity-80" />
      <blockquote data-reveal-lines class="mt-phi-2 pull text-2xl leading-relaxed text-mist sm:text-3xl">
        “Weapons do not cut it, fire does not burn it, water does not wet it, and the
        wind does not dry it. For the soul is eternal, all-pervading, unchanging,
        immovable, and primeval.”
      </blockquote>
      <p class="reveal mt-7 accent text-gold">Bhagavad Gītā 2.23</p>
    </div>
  </section>

  <!-- ░░ FLAGSHIP — The Cosmos & the Sheaths (live 3D, lazy-loaded) ░░ -->
  <div class="border-t border-white/10">
    <KosaScene />
  </div>

  <!-- ░░ ARTWORKS — unnamed, alongside the path ░░ -->
  <section class="relative border-t border-white/10">
    <div class="mx-auto max-w-4xl px-6 py-phi-4">
      <div class="mx-auto grid gap-6 sm:grid-cols-3">
        <div class="art-frame">
          <ArtPlate variant="yantra" />
        </div>
        <div class="art-frame">
          <ArtPlate variant="sahasrara" />
        </div>
        <div class="art-frame">
          <ArtPlate variant="stardust" />
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ WHERE TO BEGIN ░░ -->
  <section class="relative border-t border-white/10">
    <div class="mx-auto max-w-6xl px-6 py-phi-4">
      <p class="reveal kicker">02 — Where to Begin</p>
      <div class="mx-auto mt-phi-2 grid gap-6 md:grid-cols-2">
        <a href="/knowledge" class="reveal card-soul group p-phi-2">
          <span class="font-sans text-[0.6rem] uppercase tracking-[0.3em] text-gold/70">{articles.length} writings</span>
          <h3 class="mt-3 display-lg text-mist">Knowledge Hub</h3>
          <p class="mt-4 font-serif text-lg leading-relaxed text-mist/65">
            Reflections and resources on life, Spirit and the soul — to read slowly.
          </p>
          <span class="mt-7 inline-flex items-center gap-2 font-sans text-[0.66rem] uppercase tracking-[0.22em] text-mist transition-phi group-hover:text-gold"
            >Enter <span aria-hidden="true" class="transition-phi group-hover:translate-x-1">&rarr;</span></span
          >
        </a>
        <a href="/courses" class="reveal-delay card-soul group p-phi-2">
          <span class="font-sans text-[0.6rem] uppercase tracking-[0.3em] text-gold/70">{courses.length} courses</span>
          <h3 class="mt-3 display-lg text-mist">Courses</h3>
          <p class="mt-4 font-serif text-lg leading-relaxed text-mist/65">
            Guided journeys, structured as small books with chapters, glossaries and quizzes.
          </p>
          <span class="mt-7 inline-flex items-center gap-2 font-sans text-[0.66rem] uppercase tracking-[0.22em] text-mist transition-phi group-hover:text-gold"
            >Enter <span aria-hidden="true" class="transition-phi group-hover:translate-x-1">&rarr;</span></span
          >
        </a>
      </div>
    </div>
  </section>
</Layout>
