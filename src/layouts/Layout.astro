---
import '@fontsource/eb-garamond/latin-400.css';
import '@fontsource/eb-garamond/latin-500.css';
import '@fontsource/eb-garamond/latin-600.css';
import '@fontsource/eb-garamond/latin-700.css';
import '@fontsource/eb-garamond/latin-400-italic.css';
import '@fontsource/eb-garamond/latin-500-italic.css';
import '../styles/global.css';
import Logo from '../components/Logo.astro';

interface Props {
  title?: string;
  description?: string;
  hasSearch?: boolean;
  theme?: 'light' | 'dark';
}

const {
  title = 'Soul Seeking — Higher Answers for Deeper Questions',
  description = 'A quiet quest within. Explore life\u2019s bigger mysteries, spirituality and the inner Self through authentic Vedic wisdom, courses and reflections.',
  hasSearch = false,
  theme = 'light',
} = Astro.props;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/knowledge', label: 'Knowledge Hub' },
  { href: '/courses', label: 'Courses' },
  { href: '/donate', label: 'Donate' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const h = href.replace(/\/$/, '') || '/';
  if (h === '/') return path === '/';
  return path === h || path.startsWith(h + '/');
};
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; manifest-src 'self'; upgrade-insecure-requests"
    />
    <meta name="referrer" content="no-referrer" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#15110D" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Soul Seeking" />
    <meta name="twitter:card" content="summary" />
    {hasSearch && <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />}
  </head>
  <body
    class={`font-serif min-h-screen flex flex-col ${theme === 'dark' ? 'bg-cosmos text-cream' : 'bg-cream text-earth'}`}
  >
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-cream focus:text-earth focus:px-4 focus:py-2"
      >Skip to content</a
    >

    <header
      class="sticky top-0 z-40 border-b border-gold/30 bg-cream/90 backdrop-blur supports-[backdrop-filter]:bg-cream/75"
    >
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4">
        <a href="/" class="transition-phi hover:opacity-80" aria-label="Soul Seeking home">
          <span class="flex items-center gap-3">
            <Logo size={40} tone="earth" />
            <span class="flex flex-col leading-none">
              <span class="text-sm tracking-extreme uppercase text-earth sm:text-base">Soul Seeking</span>
              <span class="mt-1 hidden text-[0.5rem] tracking-ultra uppercase text-ochre sm:block"
                >Higher answers for deeper questions</span
              >
            </span>
          </span>
        </a>

        <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class={`text-[0.7rem] uppercase tracking-extreme transition-phi hover:opacity-70 ${isActive(item.href) ? 'text-oxblood' : 'text-earth'}`}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
          <a href="/search" class="text-earth transition-phi hover:opacity-70" aria-label="Search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="11" cy="11" r="7"></circle>
              <line x1="16.5" y1="16.5" x2="21" y2="21" stroke-linecap="round"></line>
            </svg>
          </a>
        </nav>

        <!-- mobile menu toggle -->
        <button
          id="navToggle"
          class="text-earth md:hidden"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobileNav"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <line x1="3" y1="7" x2="21" y2="7" stroke-linecap="round"></line>
            <line x1="3" y1="12" x2="21" y2="12" stroke-linecap="round"></line>
            <line x1="3" y1="17" x2="21" y2="17" stroke-linecap="round"></line>
          </svg>
        </button>
      </div>

      <nav
        id="mobileNav"
        class="hidden border-t border-gold/30 bg-cream px-5 py-4 md:hidden"
        aria-label="Mobile"
      >
        <ul class="flex flex-col gap-4">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class={`block text-sm uppercase tracking-extreme ${isActive(item.href) ? 'text-oxblood' : 'text-earth'}`}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href="/search" class="block text-sm uppercase tracking-extreme text-earth">Search</a>
          </li>
        </ul>
      </nav>
    </header>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="mt-phi-3 border-t border-gold/30 bg-cosmos text-cream">
      <div class="mx-auto max-w-6xl px-5 py-phi-3">
        <div class="flex flex-col items-center gap-5 text-center">
          <Logo size={42} tone="gold" />
          <p class="accent text-gold">
            Soul Seeking &middot; Uncovering Life, Truth &amp; Spirit &middot; Step by Step
          </p>
          <div class="rule-gold w-40"></div>
          <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2" aria-label="Footer">
            {
              nav.concat({ href: '/search', label: 'Search' }).map((item) => (
                <a href={item.href} class="text-[0.65rem] uppercase tracking-extreme text-cream/70 hover:text-gold">
                  {item.label}
                </a>
              ))
            }
          </nav>
          <p class="max-w-md text-xs leading-relaxed text-cream/50">
            No trackers. No cookies. No contact avenues. The path continues onward,
            independently — what you seek, you will attract.
          </p>
          <p class="text-[0.6rem] uppercase tracking-extreme text-cream/40">
            &copy; {year} Soul Seeking
          </p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('navToggle');
      const menu = document.getElementById('mobileNav');
      if (toggle && menu) {
        toggle.addEventListener('click', () => {
          const open = menu.classList.toggle('hidden') === false;
          toggle.setAttribute('aria-expanded', String(open));
        });
      }
    </script>
  </body>
</html>
