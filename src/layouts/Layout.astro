---
import '@fontsource-variable/space-grotesk';
import '@fontsource/eb-garamond/latin-400.css';
import '@fontsource/eb-garamond/latin-500.css';
import '@fontsource/eb-garamond/latin-600.css';
import '@fontsource/eb-garamond/latin-400-italic.css';
import '@fontsource/eb-garamond/latin-500-italic.css';
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Logo from '../components/Logo.astro';
import SiteFX from '../components/SiteFX.astro';
import BrandDivider from '../components/BrandDivider.astro';
import CosmicBackground from '../components/CosmicBackground.astro';
import BrandArt from '../components/BrandArt.astro';

interface Props {
  title?: string;
  description?: string;
  hasSearch?: boolean;
  theme?: 'light' | 'dark';
  fxPage?: string;
  ogType?: string;
  image?: string;
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  keywords?: string;
  cosmos?: string;
}

const {
  title = 'Soul Seeking — Higher Answers for Deeper Questions',
  description = 'Timeless answers to life’s deepest questions — on meaning, the mind, and the Self within. A calm, modern path drawn from the world’s oldest wisdom, through courses and reflections.',
  fxPage = 'default',
  ogType = 'website',
  image = '/og.svg',
  jsonld,
  noindex = false,
  keywords = 'soul, spirituality, self-inquiry, Vedanta, Upanishads, Bhagavad Gita, meditation, consciousness, the Self, atman, kosha, meaning of life, inner peace, wisdom',
  cosmos,
} = Astro.props;

// Each page gets its own fixed, coded "universe" backdrop (text scrolls over it).
// Home keeps its bespoke HomeAtmosphere (stars + light + five rotating orbs).
const cosmosByPage: Record<string, string> = {
  home: 'home',
  about: 'nebula',
  knowledge: 'galaxy',
  courses: 'wormhole',
  donate: 'supernova',
  search: 'starfield',
  default: 'aurora',
};
const cosmosVariant = cosmos ?? cosmosByPage[fxPage] ?? cosmosByPage.default;

// A coded "human-touch" artwork per page (dot-painting / etched register).
const artByPage: Record<string, string> = {
  home: 'waterholes',
  about: 'songlines',
  knowledge: 'dotcircles',
  courses: 'weave',
  donate: 'radiance',
  search: 'lacework',
  default: 'terrain',
};
const artVariant = artByPage[fxPage] ?? artByPage.default;

// Reading-heavy hubs keep their backdrop quieter so text stays effortless.
const reading = fxPage === 'knowledge' || fxPage === 'courses';

const site = Astro.site ?? new URL('https://soulseeking.org');
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL(image, site).toString();

// ---- Structured data: Organization + WebSite (always), plus any page schema ----
const org = {
  '@type': 'Organization',
  '@id': new URL('/#org', site).toString(),
  name: 'Soul Seeking',
  url: site.toString(),
  logo: new URL('/favicon.svg', site).toString(),
  description:
    'Soul Seeking is a contemplative library on spirituality, the soul and life’s deepest questions, drawn from the Bhagavad-gītā, the Upaniṣads and the world’s wisdom traditions.',
  slogan: 'Higher answers for deeper questions',
};
const website = {
  '@type': 'WebSite',
  '@id': new URL('/#website', site).toString(),
  name: 'Soul Seeking',
  url: site.toString(),
  description,
  publisher: { '@id': new URL('/#org', site).toString() },
  inLanguage: 'en',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: new URL('/search?q={search_term_string}', site).toString(),
    },
    'query-input': 'required name=search_term_string',
  },
};
const graph = [org, website, ...(Array.isArray(jsonld) ? jsonld : jsonld ? [jsonld] : [])];
const ldjson = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/knowledge', label: 'Knowledge Hub' },
  { href: '/courses', label: 'Courses' },
  { href: '/donate', label: 'Donate' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const h = href.replace(/\/$/, '') || '/';
  if (h === '/') return path === '/';
  return path === h || path.startsWith(h + '/');
};
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Pre-paint motion setting: honour a saved choice, else the OS reduced-motion
         preference, so nothing animates before the visitor's wishes are known. -->
    <script is:inline>
      (function () {
        try {
          var pref = localStorage.getItem('ss-motion');
          var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (pref ? pref === 'off' : reduce)
            document.documentElement.setAttribute('data-motion', 'off');
        } catch (e) {}
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#E7C68B" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'sha256-a9TpvoFyaIHq3ked/4/hyu3ME8+yvng/EG86edFm2kk=' 'sha256-kK/C8vV3ACKCnNV1SkfDFQo0XBz/hxTLFz87G5QZ4oo='; connect-src 'self'; manifest-src 'self'; upgrade-insecure-requests"
    />
    <meta name="referrer" content="no-referrer" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#08080A" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Soul Seeking" />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, nofollow'
        : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="Soul Seeking" href="/rss.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Soul Seeking" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Soul Seeking — a soaring eagle over a quiet cosmos" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" is:inline set:html={ldjson} />
    <ViewTransitions />
  </head>
  <body class="min-h-screen flex flex-col bg-void text-mist" data-fx-page={fxPage}>
    <SiteFX />
    <div class="brand-veil" aria-hidden="true"></div>
    {
      cosmosVariant !== 'home' && (
        <div class={`pointer-events-none fixed inset-0 z-0 transition-opacity ${reading ? 'opacity-[0.5]' : ''}`}>
          <CosmicBackground variant={cosmosVariant} />
        </div>
      )
    }
    {/* The page's coded artwork as a fixed background image, site-wide. */}
    <div
      class={`brandart-bg pointer-events-none fixed inset-0 z-0 ${reading ? 'opacity-[0.045]' : 'opacity-[0.09]'}`}
      aria-hidden="true"
    >
      <BrandArt variant={artVariant} class="h-full w-full" />
    </div>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-mist focus:px-4 focus:py-2 focus:text-void"
      >Skip to content</a
    >

    <header
      class="sticky top-0 z-40 border-b border-white/10 bg-void/70 backdrop-blur-xl supports-[backdrop-filter]:bg-void/55"
    >
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4">
        <a href="/" class="transition-phi hover:opacity-80" aria-label="Soul Seeking home">
          <span class="flex items-center gap-3">
            <Logo size={38} tone="gold" />
            <span class="flex flex-col leading-none">
              <span class="font-sans text-sm font-medium tracking-[0.16em] text-mist sm:text-base"
                >SOUL SEEKING</span
              >
              <span class="mt-1 hidden font-sans text-[0.5rem] tracking-[0.3em] text-gold/80 sm:block"
                >HIGHER ANSWERS FOR DEEPER QUESTIONS</span
              >
            </span>
          </span>
        </a>

        <nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class={`font-sans text-[0.66rem] uppercase tracking-[0.22em] transition-phi hover:text-gold ${isActive(item.href) ? 'text-gold' : 'text-mist/65'}`}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
          <a href="/search" class="text-mist/65 transition-phi hover:text-gold" aria-label="Search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="11" cy="11" r="7"></circle>
              <line x1="16.5" y1="16.5" x2="21" y2="21" stroke-linecap="round"></line>
            </svg>
          </a>
        </nav>

        <!-- mobile menu toggle -->
        <button
          id="navToggle"
          class="text-mist md:hidden"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobileNav"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <line x1="3" y1="7" x2="21" y2="7" stroke-linecap="round"></line>
            <line x1="3" y1="12" x2="21" y2="12" stroke-linecap="round"></line>
            <line x1="3" y1="17" x2="21" y2="17" stroke-linecap="round"></line>
          </svg>
        </button>
      </div>

      <nav
        id="mobileNav"
        class="hidden border-t border-white/10 bg-void px-5 py-4 md:hidden"
        aria-label="Mobile"
      >
        <ul class="flex flex-col gap-4">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class={`block font-sans text-sm uppercase tracking-[0.22em] ${isActive(item.href) ? 'text-gold' : 'text-mist/70'}`}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href="/search" class="block font-sans text-sm uppercase tracking-[0.22em] text-mist/70">Search</a>
          </li>
        </ul>
      </nav>
    </header>

    <main id="main" class="relative z-10 flex-1">
      <slot />
    </main>

    <BrandDivider class="relative z-10 mt-phi-3" />

    <footer class="relative z-10 overflow-hidden border-t border-white/10 bg-abyss text-mist">
      <div class="pointer-events-none absolute inset-0 aurora opacity-50"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.08]">
        <BrandArt variant={artVariant} class="h-full w-full" />
      </div>
      <div class="relative z-10 mx-auto max-w-6xl px-5 py-phi-3">
        <div class="flex flex-col items-center gap-5 text-center">
          <Logo size={40} tone="gold" />
          <p class="accent text-gold">
            Uncovering Life, Truth &amp; Spirit &middot; Step by Step
          </p>
          <div class="rule-gold w-40"></div>
          <nav class="flex flex-wrap items-center justify-center gap-x-7 gap-y-2" aria-label="Footer">
            {
              nav.concat({ href: '/search', label: 'Search' }).map((item) => (
                <a href={item.href} class="font-sans text-[0.62rem] uppercase tracking-[0.22em] text-mist/55 transition-phi hover:text-gold">
                  {item.label}
                </a>
              ))
            }
          </nav>
          <p class="max-w-md font-serif text-sm leading-relaxed text-mist/45">
            No trackers. No cookies. No contact avenues. The path continues onward,
            independently — what you seek, you will attract.
          </p>
          <button
            id="motionToggle"
            type="button"
            aria-pressed="true"
            class="inline-flex min-h-[2.75rem] items-center gap-2 rounded-full border border-white/15 px-4 py-2 font-sans text-[0.58rem] uppercase tracking-[0.22em] text-mist/65 transition-phi hover:border-gold hover:text-gold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span data-motion-label>Motion: On</span>
          </button>
          <p class="font-sans text-[0.58rem] uppercase tracking-[0.22em] text-mist/35">
            &copy; {year} Soul Seeking
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Re-bind chrome on every navigation — with View Transitions the header
      // and footer are swapped, so once-bound listeners would otherwise be lost
      // (the mobile menu only worked after a full reload).
      function bindChrome() {
        const toggle = document.getElementById('navToggle');
        const menu = document.getElementById('mobileNav');
        if (toggle && menu && toggle.dataset.bound !== '1') {
          toggle.dataset.bound = '1';
          toggle.addEventListener('click', () => {
            const open = menu.classList.toggle('hidden') === false;
            toggle.setAttribute('aria-expanded', String(open));
          });
        }

        // Persistent Motion: on/off control.
        const root = document.documentElement;
        const motionBtn = document.getElementById('motionToggle');
        if (motionBtn) {
          const label = motionBtn.querySelector('[data-motion-label]');
          const sync = () => {
            const off = root.getAttribute('data-motion') === 'off';
            motionBtn.setAttribute('aria-pressed', String(!off));
            motionBtn.setAttribute(
              'aria-label',
              off ? 'Motion is off. Turn gentle motion on.' : 'Motion is on. Turn gentle motion off.'
            );
            if (label) label.textContent = off ? 'Motion: Off' : 'Motion: On';
          };
          sync();
          if (motionBtn.dataset.bound !== '1') {
            motionBtn.dataset.bound = '1';
            motionBtn.addEventListener('click', () => {
              const off = root.getAttribute('data-motion') === 'off';
              if (off) root.removeAttribute('data-motion');
              else root.setAttribute('data-motion', 'off');
              try {
                localStorage.setItem('ss-motion', off ? 'on' : 'off');
              } catch (e) {}
              sync();
              window.dispatchEvent(new CustomEvent('ss-motion-change'));
            });
          }
        }
      }

      bindChrome();
      document.addEventListener('astro:page-load', bindChrome);
    </script>
  </body>
</html>
