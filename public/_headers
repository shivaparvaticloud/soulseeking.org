/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Origin-Agent-Cluster: ?1
  X-Permitted-Cross-Domain-Policies: none
  X-DNS-Prefetch-Control: off
  X-Download-Options: noopen
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), bluetooth=(), midi=(), serial=(), hid=(), browsing-topics=(), interest-cohort=(), autoplay=(), display-capture=(), fullscreen=(self)
  Content-Security-Policy: default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'sha256-a9TpvoFyaIHq3ked/4/hyu3ME8+yvng/EG86edFm2kk=' 'sha256-kK/C8vV3ACKCnNV1SkfDFQo0XBz/hxTLFz87G5QZ4oo='; connect-src 'self'; worker-src 'self'; manifest-src 'self'; media-src 'self'; child-src 'none'; upgrade-insecure-requests
  X-Robots-Tag: index, follow, noai, noimageai

# Hashed, content-addressed bundles — cache hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/search-index.json
  Cache-Control: public, max-age=3600
